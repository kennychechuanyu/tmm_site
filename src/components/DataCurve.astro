---
/**
 * DataCurve — TMM's signature animation: a "measurement network."
 *
 * Drifting observed nodes (navy) connect to their neighbours by proximity, and
 * a few glowing latent-factor hubs (salmon) draw the nearby nodes toward them.
 * It pictures a factor / measurement model: latent constructs, their indicators,
 * and the covariance web among observations. A connected constellation in the
 * spirit of a star map, but built from TMM's own ideas and palette.
 *
 * Theme-aware (light + dark), masked to the lower hero so it never crosses the
 * left-aligned titles, pointer-reactive, pauses offscreen, and renders a single
 * static frame under prefers-reduced-motion.
 */
interface Props {
  class?: string;
}
const { class: extraClass = "" } = Astro.props;
---

<canvas
  data-datacurve
  class:list={["pointer-events-none absolute inset-0 h-full w-full", extraClass]}
  style="-webkit-mask-image: linear-gradient(72deg, transparent 40%, #000 66%); mask-image: linear-gradient(72deg, transparent 40%, #000 66%);"
  aria-hidden="true"></canvas>

<script>
  function initDataCurve() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>("canvas[data-datacurve]");
    if (!canvases.length) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    canvases.forEach((canvas) => {
      if (canvas.dataset.init === "1") return;
      canvas.dataset.init = "1";
      const ctx = canvas.getContext("2d");
      const parent = canvas.parentElement as HTMLElement | null;
      if (!ctx || !parent) return;

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let w = 0, h = 0, raf = 0, running = false;
      const LINK = 132;
      const HUB_LINK = 188;

      type N = { x: number; y: number; vx: number; vy: number; r: number };
      let nodes: N[] = [];
      let hubs: N[] = [];
      const pointer = { x: -9999, y: -9999, on: false };

      function palette() {
        const dark = document.documentElement.classList.contains("dark");
        return dark
          ? { node: "150, 175, 220", edge: "120, 150, 210", hub: "250, 128, 114", nodeA: 0.55, edgeA: 0.5 }
          : { node: "58, 102, 200", edge: "58, 102, 200", hub: "240, 106, 90", nodeA: 0.55, edgeA: 0.45 };
      }

      function rand(a: number, b: number) {
        return a + Math.random() * (b - a);
      }

      function build() {
        const count = Math.min(78, Math.max(34, Math.round((w * h) / 17000)));
        nodes = Array.from({ length: count }, () => ({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: rand(-0.18, 0.18),
          vy: rand(-0.18, 0.18),
          r: rand(1, 2.3),
        }));
        const hubCount = w < 700 ? 2 : w < 1100 ? 3 : 4;
        hubs = Array.from({ length: hubCount }, () => ({
          x: rand(w * 0.46, w * 0.97),
          y: rand(h * 0.12, h * 0.82),
          vx: rand(-0.1, 0.1),
          vy: rand(-0.07, 0.07),
          r: rand(3.2, 4.6),
        }));
      }

      function resize() {
        w = parent!.clientWidth;
        h = parent!.clientHeight;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
        build();
      }

      function move(n: N, jitter: boolean) {
        n.x += n.vx;
        n.y += n.vy;
        if (n.x < -30) n.x = w + 30;
        if (n.x > w + 30) n.x = -30;
        if (n.y < -30) n.y = h + 30;
        if (n.y > h + 30) n.y = -30;
        if (jitter && pointer.on) {
          const dx = pointer.x - n.x, dy = pointer.y - n.y;
          const d = Math.hypot(dx, dy);
          if (d < 130 && d > 0.1) {
            n.x += (dx / d) * 0.25;
            n.y += (dy / d) * 0.25;
          }
        }
      }

      function draw() {
        const c = palette();
        ctx!.clearRect(0, 0, w, h);

        // Node-to-node covariance web
        for (let i = 0; i < nodes.length; i++) {
          const a = nodes[i];
          for (let j = i + 1; j < nodes.length; j++) {
            const b = nodes[j];
            const dx = a.x - b.x, dy = a.y - b.y;
            const dist = Math.hypot(dx, dy);
            if (dist < LINK) {
              ctx!.strokeStyle = `rgba(${c.edge}, ${(1 - dist / LINK) * c.edgeA * 0.6})`;
              ctx!.lineWidth = 0.7;
              ctx!.beginPath();
              ctx!.moveTo(a.x, a.y);
              ctx!.lineTo(b.x, b.y);
              ctx!.stroke();
            }
          }
          // Edge toward the cursor
          if (pointer.on) {
            const d = Math.hypot(a.x - pointer.x, a.y - pointer.y);
            if (d < LINK * 1.4) {
              ctx!.strokeStyle = `rgba(${c.hub}, ${(1 - d / (LINK * 1.4)) * 0.5})`;
              ctx!.lineWidth = 0.8;
              ctx!.beginPath();
              ctx!.moveTo(a.x, a.y);
              ctx!.lineTo(pointer.x, pointer.y);
              ctx!.stroke();
            }
          }
        }

        // Loadings: nodes link to nearby latent hubs (salmon)
        for (const hub of hubs) {
          for (const n of nodes) {
            const dx = hub.x - n.x, dy = hub.y - n.y;
            const dist = Math.hypot(dx, dy);
            if (dist < HUB_LINK) {
              ctx!.strokeStyle = `rgba(${c.hub}, ${(1 - dist / HUB_LINK) * 0.32})`;
              ctx!.lineWidth = 0.8;
              ctx!.beginPath();
              ctx!.moveTo(hub.x, hub.y);
              ctx!.lineTo(n.x, n.y);
              ctx!.stroke();
            }
          }
        }

        // Observed nodes
        for (const n of nodes) {
          ctx!.fillStyle = `rgba(${c.node}, ${c.nodeA})`;
          ctx!.beginPath();
          ctx!.arc(n.x, n.y, n.r, 0, Math.PI * 2);
          ctx!.fill();
        }

        // Latent hubs with glow
        for (const hub of hubs) {
          const g = ctx!.createRadialGradient(hub.x, hub.y, 0, hub.x, hub.y, hub.r * 5);
          g.addColorStop(0, `rgba(${c.hub}, 0.45)`);
          g.addColorStop(1, `rgba(${c.hub}, 0)`);
          ctx!.fillStyle = g;
          ctx!.beginPath();
          ctx!.arc(hub.x, hub.y, hub.r * 5, 0, Math.PI * 2);
          ctx!.fill();
          ctx!.fillStyle = `rgba(${c.hub}, 0.95)`;
          ctx!.beginPath();
          ctx!.arc(hub.x, hub.y, hub.r, 0, Math.PI * 2);
          ctx!.fill();
        }
      }

      function step() {
        for (const n of nodes) move(n, true);
        for (const hub of hubs) move(hub, false);
        draw();
      }

      function loop() {
        step();
        raf = requestAnimationFrame(loop);
      }
      function start() {
        if (!running && !reduce) {
          running = true;
          loop();
        }
      }
      function stop() {
        running = false;
        cancelAnimationFrame(raf);
      }

      const io = new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop()), { threshold: 0 });
      io.observe(canvas);

      parent.addEventListener("pointermove", (e) => {
        const rect = canvas.getBoundingClientRect();
        pointer.x = e.clientX - rect.left;
        pointer.y = e.clientY - rect.top;
        pointer.on = true;
      });
      parent.addEventListener("pointerleave", () => (pointer.on = false));

      let rt: number;
      window.addEventListener("resize", () => {
        clearTimeout(rt);
        rt = window.setTimeout(resize, 150);
      });

      resize();
      draw();
    });
  }

  initDataCurve();
  document.addEventListener("astro:after-swap", initDataCurve);
</script>
