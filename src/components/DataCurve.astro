---
/**
 * DataCurve — TMM's signature animation: "the predictive distribution in motion."
 *
 * A central model curve (salmon) is wrapped in nested, translucent credible-
 * interval bands (navy), with a few fine sample draws flowing inside. It reads
 * as a model, its uncertainty, and the data realisations it generates — the
 * theory → model → measurement loop, rendered as soft layered motion rather
 * than a scatterplot.
 *
 * Theme-aware (light + dark), masked into the lower-right so it never crosses
 * the left-aligned titles, pauses offscreen, and renders a single static frame
 * under prefers-reduced-motion.
 */
interface Props {
  class?: string;
}
const { class: extraClass = "" } = Astro.props;
---

<canvas
  data-datacurve
  class:list={["pointer-events-none absolute inset-0 h-full w-full", extraClass]}
  style="-webkit-mask-image: radial-gradient(135% 150% at 76% 102%, #000 44%, transparent 84%); mask-image: radial-gradient(135% 150% at 76% 102%, #000 44%, transparent 84%);"
  aria-hidden="true"></canvas>

<script>
  function initDataCurve() {
    const canvases = document.querySelectorAll<HTMLCanvasElement>("canvas[data-datacurve]");
    if (!canvases.length) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    canvases.forEach((canvas) => {
      if (canvas.dataset.init === "1") return;
      canvas.dataset.init = "1";
      const ctx = canvas.getContext("2d");
      const parent = canvas.parentElement as HTMLElement | null;
      if (!ctx || !parent) return;

      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      let w = 0, h = 0, t = 0, raf = 0, running = false;

      const SEG = 128;
      const DRAWS = [
        { phase: 0.0, freq: 3.1, amp: 0.64 },
        { phase: 1.7, freq: 4.3, amp: 0.5 },
        { phase: 3.2, freq: 2.6, amp: 0.74 },
        { phase: 4.8, freq: 5.0, amp: 0.42 },
        { phase: 2.3, freq: 3.7, amp: 0.58 },
      ];

      function palette() {
        const dark = document.documentElement.classList.contains("dark");
        return dark
          ? { band: "120, 160, 240", model: "250, 128, 114", draw: "165, 180, 205", bandA: 0.06, drawA: 0.17, glow: 12 }
          : { band: "58, 102, 200", model: "240, 106, 90", draw: "58, 102, 200", bandA: 0.085, drawA: 0.2, glow: 9 };
      }

      // Expectation curve (fraction 0..1), slowly morphing.
      function mean(xf: number, time: number) {
        return (
          0.5 +
          0.12 * Math.sin(xf * 2.4 + time * 0.42) +
          0.05 * Math.sin(xf * 4.9 - time * 0.3 + 1.2)
        );
      }
      // Vertical centre of the ribbon, kept in the lower band.
      const midY = (xf: number) => mean(xf, t) * h * 0.34 + h * 0.6;
      // Half-width of the uncertainty band (px), wider toward the middle, breathing.
      function halfWidth(xf: number) {
        const envelope = 0.42 + 0.58 * Math.sin(Math.max(0, Math.min(1, xf)) * Math.PI);
        return h * 0.082 * envelope * (0.78 + 0.22 * Math.sin(xf * 1.7 + t * 0.35));
      }

      function band(k: number, rgb: string, alpha: number) {
        ctx!.beginPath();
        for (let i = 0; i <= SEG; i++) {
          const xf = i / SEG;
          const x = xf * w;
          const y = midY(xf) - k * halfWidth(xf);
          i ? ctx!.lineTo(x, y) : ctx!.moveTo(x, y);
        }
        for (let i = SEG; i >= 0; i--) {
          const xf = i / SEG;
          ctx!.lineTo(xf * w, midY(xf) + k * halfWidth(xf));
        }
        ctx!.closePath();
        ctx!.fillStyle = `rgba(${rgb}, ${alpha})`;
        ctx!.fill();
      }

      function stroke(yOf: (xf: number) => number, rgb: string, alpha: number, lw: number) {
        ctx!.beginPath();
        for (let i = 0; i <= SEG; i++) {
          const xf = i / SEG;
          const x = xf * w;
          const y = yOf(xf);
          i ? ctx!.lineTo(x, y) : ctx!.moveTo(x, y);
        }
        ctx!.strokeStyle = `rgba(${rgb}, ${alpha})`;
        ctx!.lineWidth = lw;
        ctx!.lineJoin = "round";
        ctx!.stroke();
      }

      function draw() {
        const c = palette();
        ctx!.clearRect(0, 0, w, h);

        // Nested credible-interval bands (alpha accumulates toward the centre).
        band(1.0, c.band, c.bandA * 0.85);
        band(0.6, c.band, c.bandA);
        band(0.28, c.band, c.bandA * 1.15);

        // Defined upper contour of the band, for a crisp edge.
        stroke((xf) => midY(xf) - halfWidth(xf), c.band, c.bandA * 2.4, 1);

        // Fine sample draws flowing inside the band.
        for (const d of DRAWS) {
          stroke(
            (xf) => midY(xf) + Math.sin(xf * d.freq + t * 0.5 + d.phase) * halfWidth(xf) * d.amp,
            c.draw,
            c.drawA,
            1,
          );
        }

        // The model curve (expectation), with a soft glow.
        ctx!.save();
        ctx!.shadowColor = `rgba(${c.model}, 0.5)`;
        ctx!.shadowBlur = c.glow;
        stroke((xf) => midY(xf), c.model, 0.62, 1.6);
        ctx!.restore();
      }

      function loop() {
        t += 0.005;
        draw();
        raf = requestAnimationFrame(loop);
      }
      function start() {
        if (!running && !reduce) {
          running = true;
          loop();
        }
      }
      function stop() {
        running = false;
        cancelAnimationFrame(raf);
      }

      function resize() {
        w = parent!.clientWidth;
        h = parent!.clientHeight;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
        draw();
      }

      const io = new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop()), { threshold: 0 });
      io.observe(canvas);

      let rt: number;
      window.addEventListener("resize", () => {
        clearTimeout(rt);
        rt = window.setTimeout(resize, 150);
      });

      resize();
    });
  }

  initDataCurve();
  document.addEventListener("astro:after-swap", initDataCurve);
</script>
