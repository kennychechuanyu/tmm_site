---
import ChapterHeader from "./ChapterHeader.astro";

interface Props {
  title?: string;
  subtitle?: string;
  numeral?: string;
  metaLabel?: string;
  centered?: boolean;
  background?: "white" | "gray" | "navy";
  id?: string;
}

const {
  title,
  subtitle,
  numeral,
  metaLabel,
  centered = false,
  background = "white",
  id,
} = Astro.props;

const bgClasses = {
  white: "bg-white dark:bg-slate-900",
  gray: "bg-slate-50 dark:bg-slate-950",
  navy: "bg-navy-50 dark:bg-navy-950",
};
---

<section id={id} class:list={["section", bgClasses[background]]}>
  <div class="container-wide">
    {title && (
      <div class="mb-12 md:mb-16">
        <ChapterHeader numeral={numeral} title={title} metaLabel={metaLabel} />
        {subtitle && (
          <p
            class:list={[
              "mt-6 font-serif text-lg italic text-slate-600 dark:text-slate-400 md:text-xl",
              centered && "mx-auto text-center",
            ]}
          >
            {subtitle}
          </p>
        )}
      </div>
    )}

    <slot />
  </div>
</section>
