---
/**
 * Search.astro — site-wide search powered by Pagefind.
 *
 * Pagefind indexes the built HTML at build time (see package.json:
 * `astro build && pagefind --site dist`). The runtime bundle is emitted to
 * /pagefind/, so search works in `astro preview` and in production. It is NOT
 * available in `astro dev` (nothing is indexed yet) — there the modal shows a
 * short notice instead of erroring.
 *
 * Opened by any element with [data-search-open] (the header buttons) and by the
 * Cmd/Ctrl+K or "/" keyboard shortcuts. The Pagefind library is loaded lazily on
 * first open so it never costs anything on initial page load.
 */
---

<dialog
  id="search-modal"
  class="search-dialog w-[calc(100%-2rem)] max-w-2xl rounded-2xl border border-slate-200 bg-white p-0 text-slate-900 shadow-2xl dark:border-slate-700 dark:bg-slate-900 dark:text-slate-100"
  aria-label="Search"
>
  <div class="max-h-[80vh] overflow-y-auto p-3 sm:p-4">
    <div id="search"></div>
    <div
      class="mt-3 flex items-center justify-between gap-4 border-t border-slate-100 px-1 pt-3 font-sans text-[11px] text-slate-400 dark:border-slate-800 dark:text-slate-500"
    >
      <span>Search papers, people, events &amp; news</span>
      <span class="flex items-center gap-1.5">
        <kbd class="rounded border border-slate-200 px-1.5 py-px font-sans text-[10px] dark:border-slate-700">Esc</kbd>
        to close
      </span>
    </div>
  </div>
</dialog>

<script>
  (() => {
    if ((window as any).__tmmSearchBound) return;
    (window as any).__tmmSearchBound = true;

    let libReady: Promise<boolean> | null = null;

    function loadLib(): Promise<boolean> {
      if (libReady) return libReady;
      libReady = new Promise<boolean>((resolve) => {
        const css = document.createElement("link");
        css.rel = "stylesheet";
        css.href = "/pagefind/pagefind-ui.css";
        document.head.appendChild(css);

        const js = document.createElement("script");
        js.src = "/pagefind/pagefind-ui.js";
        js.onload = () => resolve(true);
        js.onerror = () => resolve(false);
        document.head.appendChild(js);
      });
      return libReady;
    }

    function getModal(): HTMLDialogElement | null {
      return document.getElementById("search-modal") as HTMLDialogElement | null;
    }

    async function openSearch() {
      const modal = getModal();
      if (!modal) return;
      const mount = document.getElementById("search");
      const ok = await loadLib();
      const PagefindUI = (window as any).PagefindUI;

      if (ok && PagefindUI && mount && mount.childElementCount === 0) {
        new PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          autofocus: true,
          placeholder: "Search the TMM network…",
        });
      } else if (!ok && mount && mount.childElementCount === 0) {
        mount.innerHTML =
          '<p class="px-1 py-8 text-center font-sans text-sm text-slate-400 dark:text-slate-500">Search runs on the built site. Visit the live site or run a production build to use it.</p>';
      }

      if (!modal.open) modal.showModal();
      requestAnimationFrame(() => {
        const input = modal.querySelector("input");
        if (input) (input as HTMLInputElement).focus();
      });
    }

    function closeSearch() {
      const modal = getModal();
      if (modal && modal.open) modal.close();
    }

    // Open triggers (delegated) + click-outside to close.
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (target.closest("[data-search-open]")) {
        e.preventDefault();
        openSearch();
        return;
      }
      const modal = getModal();
      if (modal && e.target === modal) closeSearch();
    });

    // Keyboard: Cmd/Ctrl+K toggles, "/" opens (when not already typing).
    document.addEventListener("keydown", (e) => {
      const tag = (e.target as HTMLElement)?.tagName;
      const typing = tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT";
      const modal = getModal();
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === "k") {
        e.preventDefault();
        modal && modal.open ? closeSearch() : openSearch();
      } else if (e.key === "/" && !typing && !(modal && modal.open)) {
        e.preventDefault();
        openSearch();
      }
    });
  })();
</script>

<style is:global>
  /* Command-palette placement: anchored near the top, horizontally centered. */
  dialog.search-dialog {
    margin: 9vh auto auto;
  }
  dialog.search-dialog::backdrop {
    background: rgba(15, 23, 42, 0.4);
    backdrop-filter: blur(3px);
  }

  /* Theme Pagefind's UI to match TMM. Variables live on the mounted .pagefind-ui
     element so they win over Pagefind's own defaults. */
  #search-modal .pagefind-ui {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #3a66c8; /* navy */
    --pagefind-ui-text: #334155; /* slate-700 */
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #e2e8f0; /* slate-200 */
    --pagefind-ui-tag: #f1f5f9; /* slate-100 */
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 10px;
    --pagefind-ui-font: "Inter", ui-sans-serif, system-ui, sans-serif;
  }
  .dark #search-modal .pagefind-ui {
    --pagefind-ui-primary: #93b0ec; /* light navy */
    --pagefind-ui-text: #e2e8f0; /* slate-200 */
    --pagefind-ui-background: #0f172a; /* slate-900 */
    --pagefind-ui-border: #334155; /* slate-700 */
    --pagefind-ui-tag: #1e293b; /* slate-800 */
  }

  /* Editorial touches layered over Pagefind's defaults. */
  #search-modal .pagefind-ui__search-input {
    font-weight: 500;
  }
  #search-modal .pagefind-ui__result-title {
    font-family: "Lora", Georgia, serif;
  }
  #search-modal .pagefind-ui__result-link:hover {
    color: #f06a5a; /* salmon, matching site link hovers */
    text-decoration: underline;
  }
  /* Soft salmon highlight instead of Pagefind's default yellow. */
  #search-modal .pagefind-ui__result-excerpt mark {
    background: #fcdcd6;
    color: #b23a2a;
    border-radius: 2px;
    padding: 0 1px;
  }
  .dark #search-modal .pagefind-ui__result-excerpt mark {
    background: rgba(240, 106, 90, 0.28);
    color: #f7b3a8;
  }
</style>
