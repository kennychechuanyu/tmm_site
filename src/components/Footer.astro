---
const currentYear = new Date().getFullYear();

const nav = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "People", href: "/people" },
  { label: "Events", href: "/events" },
  { label: "News", href: "/news" },
  { label: "Resources", href: "/resources" },
  { label: "Community", href: "/community" },
  { label: "Contact", href: "/contact" },
];
---

<footer class="relative overflow-hidden border-t border-slate-900/10 bg-white dark:border-slate-100/10 dark:bg-slate-950">
  <!-- Dotted paper texture — the TMM page-header signature -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 text-slate-900 opacity-[0.04] dark:text-slate-100 dark:opacity-[0.07]"
    style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 32px 32px;"
  ></div>

  <div class="container-wide relative py-16 md:py-20">
    <!-- Closing masthead -->
    <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
          <span aria-hidden="true" class="inline-block h-px w-10 bg-salmon-500/80 dark:bg-salmon-400/80"></span>
          <span>The TMM Network</span>
        </div>
        <p class="mt-5 font-serif leading-[1.08] tracking-[-0.01em] text-slate-900 dark:text-slate-100" style="font-size: clamp(1.75rem, 4vw, 2.5rem);">
          Bridging theory and measurement<br class="hidden sm:block" /> in psychological science.
        </p>
      </div>

      <a
        href="/community"
        class="group inline-flex shrink-0 items-baseline gap-2 font-serif text-xl text-slate-900 dark:text-slate-100"
      >
        <span class="editorial-underline">Join the network</span>
        <span aria-hidden="true" class="text-salmon-500 transition-transform duration-300 group-hover:translate-x-1 dark:text-salmon-400">→</span>
      </a>
    </div>

    <!-- Rule -->
    <div aria-hidden="true" class="my-10 h-px bg-slate-900/10 dark:bg-slate-100/10 md:my-12"></div>

    <!-- Utility row: brand · inline nav · email -->
    <div class="flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
      <a href="/" class="flex shrink-0 items-center gap-2.5" aria-label="TMM, home">
        <svg class="h-7 w-7" viewBox="0 0 40 40" fill="none">
          <path d="M20 8 L32 28 M20 8 L8 28 M8 28 L32 28" stroke="currentColor" stroke-width="1.5" class="text-slate-400 dark:text-slate-600" />
          <circle cx="20" cy="8" r="6" class="fill-slate-700 dark:fill-slate-300" />
          <text x="20" y="11" text-anchor="middle" class="fill-white dark:fill-slate-900 text-[8px] font-bold">T</text>
          <circle cx="8" cy="28" r="6" class="fill-slate-600 dark:fill-slate-400" />
          <text x="8" y="31" text-anchor="middle" class="fill-white dark:fill-slate-900 text-[8px] font-bold">M</text>
          <circle cx="32" cy="28" r="6" class="fill-slate-600 dark:fill-slate-400" />
          <text x="32" y="31" text-anchor="middle" class="fill-white dark:fill-slate-900 text-[8px] font-bold">M</text>
        </svg>
        <span class="font-serif text-xl text-navy-600 dark:text-navy-400">TMM</span>
      </a>

      <nav class="flex flex-wrap gap-x-6 gap-y-2.5">
        {nav.map((link) => (
          <a href={link.href} class="font-sans text-sm text-slate-600 transition-colors hover:text-salmon-600 dark:text-slate-400 dark:hover:text-salmon-400">
            {link.label}
          </a>
        ))}
      </nav>

      <a
        href="mailto:tmm.psych@outlook.com"
        class="shrink-0 font-mono text-sm text-slate-600 transition-colors hover:text-salmon-600 dark:text-slate-400 dark:hover:text-salmon-400"
      >
        tmm.psych@outlook.com
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <p class="font-sans text-xs text-slate-500 dark:text-slate-500">
        &copy; {currentYear} Theory, Model, Measurement Network. All rights reserved.
      </p>
      <p class="font-sans text-[11px] uppercase text-slate-400 dark:text-slate-600" style="letter-spacing: 0.2em;">
        Theory · Model · Measurement
      </p>
    </div>
  </div>
</footer>
