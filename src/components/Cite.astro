---
/**
 * Cite.astro — a small "Cite" disclosure that reveals an APA reference.
 *
 * The toggle is a native <details>/<summary> (no JS needed to open). The only
 * script handles the Copy button; it is delegated and bound once, so any number
 * of <Cite> instances on a page share it. Build the strings with apaCitation /
 * apaCitationHtml from src/data/collections.ts.
 */
interface Props {
  citation: string; // plain text, copied to the clipboard
  citationHtml: string; // HTML (venue italicised, DOI linked) for display
  class?: string;
}
const { citation, citationHtml, class: cls = "" } = Astro.props;
---

<details class:list={["cite group/cite", cls]}>
  <summary
    class="inline-flex w-fit cursor-pointer items-center gap-1.5 font-sans text-xs font-medium text-slate-500 transition-colors hover:text-salmon-600 dark:text-slate-400 dark:hover:text-salmon-400"
  >
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 7.5H6.75A2.25 2.25 0 0 0 4.5 9.75v1.5A2.25 2.25 0 0 0 6.75 13.5H9m0-6v6m0-6c0 3-1 4.5-3 5.25M19.5 7.5h-2.25A2.25 2.25 0 0 0 15 9.75v1.5a2.25 2.25 0 0 0 2.25 2.25h2.25m0-6v6m0-6c0 3-1 4.5-3 5.25" />
    </svg>
    <span class="cite-open-label">Cite</span>
  </summary>

  <div class="mt-2 rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-slate-700 dark:bg-slate-800/50">
    <p class="font-sans text-xs leading-relaxed text-slate-600 [&_a]:text-navy-600 [&_a]:underline-offset-2 hover:[&_a]:underline dark:text-slate-300 dark:[&_a]:text-navy-400" set:html={citationHtml}></p>
    <div class="mt-2.5 flex items-center gap-2">
      <span class="font-sans text-[10px] font-semibold uppercase tracking-wider text-slate-400 dark:text-slate-500">APA</span>
      <button
        type="button"
        class="cite-copy ml-auto inline-flex items-center gap-1.5 rounded-md border border-slate-200 bg-white px-2.5 py-1 font-sans text-xs font-medium text-slate-600 transition-colors hover:border-salmon-300 hover:text-salmon-600 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-300 dark:hover:text-salmon-400"
        data-citation={citation}
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m11.25 4.125v-1.5" />
        </svg>
        <span class="cite-copy-label">Copy</span>
      </button>
    </div>
  </div>
</details>

<script>
  if (!(window as any).__tmmCiteBound) {
    (window as any).__tmmCiteBound = true;
    document.addEventListener("click", async (e) => {
      const btn = (e.target as HTMLElement).closest(".cite-copy") as HTMLButtonElement | null;
      if (!btn) return;
      const text = btn.getAttribute("data-citation") || "";
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        try {
          document.execCommand("copy");
        } catch {}
        ta.remove();
      }
      const label = btn.querySelector(".cite-copy-label");
      if (label) {
        const prev = label.textContent;
        label.textContent = "Copied!";
        btn.classList.add("border-salmon-300", "text-salmon-600");
        setTimeout(() => {
          label.textContent = prev;
          btn.classList.remove("border-salmon-300", "text-salmon-600");
        }, 1600);
      }
    });
  }
</script>

<style>
  /* Remove the default disclosure triangle. */
  .cite > summary {
    list-style: none;
  }
  .cite > summary::-webkit-details-marker {
    display: none;
  }
  /* Swap the label to "Hide" when open. */
  .cite[open] > summary .cite-open-label {
    visibility: hidden;
  }
  .cite[open] > summary .cite-open-label::after {
    content: "Hide";
    visibility: visible;
    position: absolute;
  }
</style>
