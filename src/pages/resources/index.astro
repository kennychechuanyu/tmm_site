---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import ChapterHeader from "../../components/ChapterHeader.astro";
import { collections } from "../../data/collections";

const FORMSPREE_ID = "xjggvlaw";

const resourceTypes = [
  "Tutorial",
  "Paper",
  "Software/Package",
  "Dataset",
  "Slides/Presentation",
  "Video",
  "Other",
];

// Individual (non-collection) resources — long tail. Add entries here;
// they render in the filterable grid below. Empty for now.
const resources: { title: string; type: string; source: string; year: number; description: string; url: string }[] = [];
---

<PageLayout
  title="Resources"
  description="Curated resources on theory, modeling, and measurement in psychological science."
  subtitle="Curated resources on theory, modeling, and measurement in psychological science"
>
  <!-- Collections -->
  <Section background="white" compactTop>
    <div class="mx-auto max-w-5xl">
      <div class="flex items-center gap-3">
        <span class="inline-block h-px w-10 bg-salmon-500"></span>
        <span class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
          Collections
        </span>
      </div>
      <p class="mt-4 max-w-2xl font-serif text-lg italic leading-snug text-slate-600 dark:text-slate-400">
        Curated reading and discussion collections on the theory–measurement interface.
      </p>

      <div class="mt-8 grid gap-5 sm:grid-cols-2">
        {collections.map((c) => (
          <a
            href={`/resources/${c.slug}`}
            class="group flex flex-col rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:border-navy-300 hover:shadow-md hover:-translate-y-0.5 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-navy-600"
          >
            <div class="flex items-start justify-between gap-4">
              <span class="font-sans text-[10px] font-semibold uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.2em;">
                {c.type}
              </span>
              <svg class="h-4 w-4 shrink-0 text-slate-300 transition-all duration-200 group-hover:translate-x-0.5 group-hover:text-salmon-500 dark:text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h13m0 0-5.5-5.5M18 12l-5.5 5.5" />
              </svg>
            </div>
            <h2 class="mt-3 font-serif text-xl text-slate-900 transition-colors group-hover:text-navy-600 dark:text-white dark:group-hover:text-navy-400" style="line-height: 1.25;">
              {c.title}
            </h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
              {c.blurb}
            </p>
            <p class="mt-4 font-mono text-[11px] uppercase tracking-wider text-slate-400 dark:text-slate-500">
              {c.meta}
            </p>
          </a>
        ))}
      </div>
    </div>
  </Section>

  <!-- Individual resources (filterable grid) — renders when populated -->
  {resources.length > 0 && (
    <Section background="gray">
      <div class="mx-auto max-w-6xl">
        <ChapterHeader title="All Resources" />

        <!-- Type filter -->
        <div class="mt-8 flex flex-wrap gap-2" id="resource-filter">
          <button data-filter="all" class="resource-chip is-active">All</button>
          {[...new Set(resources.map((r) => r.type))].map((t) => (
            <button data-filter={t} class="resource-chip">{t}</button>
          ))}
        </div>

        <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" id="resource-grid">
          {resources.map((resource) => (
            <a
              href={resource.url}
              target="_blank"
              rel="noopener noreferrer"
              data-type={resource.type}
              class="resource-item group block rounded-xl border border-slate-200 bg-white p-6 transition-all duration-200 hover:-translate-y-0.5 hover:border-navy-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-900 dark:hover:border-navy-600"
            >
              <span class="mb-3 inline-block font-sans text-[10px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.2em;">
                {resource.type}
              </span>
              <h3 class="font-serif text-lg text-slate-900 transition-colors group-hover:text-navy-600 dark:text-white dark:group-hover:text-navy-400" style="line-height: 1.3;">
                {resource.title}
              </h3>
              <div class="mt-2 flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
                <span class="font-serif italic">{resource.source}</span>
                <span class="text-slate-300 dark:text-slate-600">&middot;</span>
                <span>{resource.year}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-slate-600 line-clamp-3 dark:text-slate-400">
                {resource.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Contribute CTA -->
  <Section background="gray">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-slate-600 dark:text-slate-400">
        Have a tutorial, tool, or paper to share? We welcome contributions from the TMM community.
      </p>
      <button id="open-modal-btn" class="btn-primary flex-shrink-0">
        Submit a Resource
      </button>
    </div>
  </Section>

  <!-- Modal -->
  <div
    id="resource-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/50 p-4"
  >
    <div class="relative my-8 w-full max-w-lg rounded-xl bg-white p-6 shadow-2xl dark:bg-slate-900">
      <button
        id="close-modal-btn"
        class="absolute right-4 top-4 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">Submit a Resource</h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        Share a resource with the TMM community.
      </p>

      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        enctype="multipart/form-data"
        class="mt-6 space-y-4"
      >
        <input type="hidden" name="_subject" value="New Resource Submission" />

        <div>
          <label for="name" class="label">Your Name *</label>
          <input type="text" id="name" name="name" required class="input" placeholder="Your name" />
        </div>

        <div>
          <label for="email" class="label">Email *</label>
          <input type="email" id="email" name="email" required class="input" placeholder="your@email.com" />
        </div>

        <div>
          <label for="title" class="label">Resource Title *</label>
          <input type="text" id="title" name="resource_title" required class="input" placeholder="Title of your resource" />
        </div>

        <div>
          <label for="type" class="label">Resource Type *</label>
          <select id="type" name="resource_type" required class="input">
            <option value="">Select type</option>
            {resourceTypes.map((type) => (
              <option value={type}>{type}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="description" class="label">Description *</label>
          <textarea id="description" name="description" required rows="3" class="input" placeholder="Brief description of the resource"></textarea>
        </div>

        <div>
          <label for="url" class="label">URL (optional)</label>
          <input type="url" id="url" name="resource_url" class="input" placeholder="https://..." />
          <p class="mt-1 text-xs text-slate-500">Link to the resource if hosted elsewhere</p>
        </div>

        <div>
          <label for="file" class="label">Upload File (optional)</label>
          <input
            type="file"
            id="file"
            name="attachment"
            class="block w-full text-sm text-slate-600 file:mr-4 file:rounded-lg file:border-0 file:bg-navy-100 file:px-4 file:py-2 file:text-sm file:font-semibold file:text-navy-700 hover:file:bg-navy-200 dark:text-slate-400 dark:file:bg-navy-900/50 dark:file:text-navy-300"
          />
          <p class="mt-1 text-xs text-slate-500">Max 10MB. PDF, DOC, PPT, or ZIP files.</p>
        </div>

        <div class="pt-2">
          <button type="submit" class="btn-primary w-full">Submit Resource</button>
        </div>
      </form>
    </div>
  </div>
</PageLayout>

<script>
  // Submit-a-resource modal
  const modal = document.getElementById("resource-modal");
  const openBtn = document.getElementById("open-modal-btn");
  const closeBtn = document.getElementById("close-modal-btn");

  function openModal() {
    modal?.classList.remove("hidden");
    modal?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }
  function closeModal() {
    modal?.classList.add("hidden");
    modal?.classList.remove("flex");
    document.body.style.overflow = "";
  }
  openBtn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal?.classList.contains("hidden")) closeModal();
  });

  // Resource type filter (for the individual-resources grid)
  const filterBar = document.getElementById("resource-filter");
  filterBar?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-filter]");
    if (!btn) return;
    const want = btn.getAttribute("data-filter");
    filterBar.querySelectorAll("[data-filter]").forEach((b) => b.classList.toggle("is-active", b === btn));
    document.querySelectorAll<HTMLElement>("#resource-grid .resource-item").forEach((item) => {
      item.style.display = want === "all" || item.getAttribute("data-type") === want ? "" : "none";
    });
  });
</script>
