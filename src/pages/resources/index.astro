---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import ChapterHeader from "../../components/ChapterHeader.astro";

const FORMSPREE_ID = "xjggvlaw";

// Resource types
const resourceTypes = [
  "Tutorial",
  "Paper",
  "Software/Package",
  "Dataset",
  "Slides/Presentation",
  "Video",
  "Other",
];

// All resources — add new ones here
const resources = [
  {
    title: "Illusions of Understanding in the Sciences",
    type: "Discussion Collection",
    source: "Computational Brain & Behavior",
    year: 2026,
    description: "Shiffrin, Stigler, and Keil argue that scientists routinely operate under predictable illusions when interpreting data, building theories, and evaluating evidence. Twenty-three commentaries respond across themes including bounded rationality, the nature of understanding, formal modeling, prediction and risk, extrapolation, replication, causal reasoning, AI, and science communication.",
    url: "https://link.springer.com/article/10.1007/s42113-026-00271-1",
    collectionUrl: "https://link.springer.com/collections/fdagffafgf",
    featured: true,
  },
];

const featured = resources.find((r) => r.featured);
const otherResources = resources.filter((r) => !r.featured);
---

<PageLayout
  title="Resources"
  description="Curated resources on theory, modeling, and measurement in psychological science."
  subtitle="Curated resources on theory, modeling, and measurement in psychological science"
>
  <!-- Featured Resource -->
  {featured && (
    <Section background="white">
      <div class="mx-auto max-w-3xl border border-slate-200 dark:border-slate-700 rounded-xl bg-white dark:bg-slate-900 shadow-sm overflow-hidden">
        <!-- Card header — always visible -->
        <div class="p-8 md:p-10">
          <!-- Eyebrow -->
          <div class="flex items-center gap-3 mb-5">
            <span class="inline-block h-px w-10 bg-salmon-500"></span>
            <span class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
              {featured.type}
            </span>
          </div>

          <!-- Title -->
          <h2 class="font-serif text-2xl font-normal text-slate-900 dark:text-white md:text-3xl" style="line-height: 1.2; letter-spacing: -0.015em;">
            {featured.title}
          </h2>

          <!-- Meta -->
          <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1">
            <span class="font-serif text-sm italic text-navy-600 dark:text-navy-400">{featured.source}</span>
            <span class="text-slate-300 dark:text-slate-600">&middot;</span>
            <span class="font-sans text-sm text-slate-500 dark:text-slate-400">{featured.year}</span>
          </div>

          <!-- Short description -->
          <p class="mt-4 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
            {featured.description}
          </p>

          <!-- Links — always visible -->
          <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2">
            <a
              href={featured.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-sans text-sm font-semibold text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
            >
              Read target article
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
            <a
              href={featured.collectionUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 font-sans text-sm font-semibold text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
            >
              Browse commentaries
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Expandable detail — collapsed by default -->
        <details class="bio-accordion group">
          <summary class="cursor-pointer select-none border-t border-slate-200 dark:border-slate-700 px-8 md:px-10 py-4 flex items-center justify-between text-sm font-medium text-navy-600 dark:text-navy-400 hover:text-salmon-600 dark:hover:text-salmon-400 transition-colors">
            <span class="bio-toggle-label">The debate in detail</span>
            <svg class="h-4 w-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="bio-content">
            <div class="overflow-hidden">
              <div class="px-8 md:px-10 pb-8 md:pb-10 space-y-6 text-[15px] leading-[1.8] text-slate-600 dark:text-slate-400 text-justify">
                <p>
                  Shiffrin, Stigler, and Keil argue that scientists routinely operate under predictable illusions: regression to the mean distorts interpretations, formal models create false confidence, findings get overgeneralized beyond their original context, and verbal summaries drift from what statistical analyses actually show. These are not occasional mistakes but systematic features of how human cognition interacts with scientific practice.
                </p>

                <p>The commentaries opened a wide-ranging debate across several fronts:</p>

                <div class="space-y-5 border-l-2 border-slate-200 dark:border-slate-700 pl-6">
                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Is the "illusion" framing itself an illusion?</p>
                    <p class="text-sm leading-relaxed">
                      Several responses push back on pathologizing normal science. Devezer and Buzbas argue that idealization and pluralism are constitutive features of scientific inquiry, not epistemic concessions. Killeen inverts the framing entirely, suggesting the target article itself creates misunderstandings about how science works. Yu, Ariens, and Vanhasbroeck argue that bounded, incomplete understanding does not invalidate it as genuine understanding: partial knowledge remains epistemically valuable and functional within the constraints of bounded rationality.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">What is understanding, anyway?</p>
                    <p class="text-sm leading-relaxed">
                      Goldstone argues there is no singular &ldquo;Understanding&rdquo; to be illuded about; scientists use multiple partial models, each illuminating different aspects. Myers and Chater challenge the implicit assumption that understanding is stored propositionally in individual minds, proposing instead that it is interactive and distributed. Motz and colleagues shift the question from what understanding is to what it is for: if partial understanding enables prediction, communication, and action, it is sufficient.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Do formal models expose blind spots or create new ones?</p>
                    <p class="text-sm leading-relaxed">
                      The target article warns that models can deceive. Soto invokes Box&rsquo;s maxim (&ldquo;all models are wrong, but some are useful&rdquo;) and proposes that models which explicitly reveal their limits are the best antidote to self-deception. Kalish distinguishes maps from windows: the illusion arises when scientists confuse their model with direct access to reality. Haaf, Cruz, and Giacobello argue that imprecision in the original essay&rsquo;s own arguments ironically demonstrates how vague language nurtures the very illusions it diagnoses.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Prediction, risk, and the limits of explanatory success</p>
                    <p class="text-sm leading-relaxed">
                      Yu and Robinson examine how predictive success creates a feeling of understanding that may not reflect genuine mechanistic insight. A model can predict well without explaining anything, and the confidence that comes from good fit is itself a species of illusion.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Extrapolation and the scope of scientific ambition</p>
                    <p class="text-sm leading-relaxed">
                      Rosenbloom and colleagues propose a unifying category, extrapolatory illusions, arguing that many of the phenomena in the target article are instances of a general tendency to extend conclusions beyond warranted bounds. Koralus, Wang-Mascianica, and Ragni offer a counterpoint: the bigger problem may be illusions of low expectations, where scientists accept superficial explanations because they set their sights too modestly.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Replication, auxiliary assumptions, and statistical reasoning</p>
                    <p class="text-sm leading-relaxed">
                      Davis-Stober, Sokratous, and Vandekerckhove extend the framework to replication itself, arguing that both successful and failed replications can be illusory. Trafimow highlights an overlooked source: the unstated auxiliary assumptions that every empirical test requires, which can make evidence for or against a theory misleading.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Causal reasoning and cognitive architecture</p>
                    <p class="text-sm leading-relaxed">
                      Liesefeld, Townsend, and Janczyk highlight the persistent difficulty of inferring cognitive causes from behavioral data: the gap between what we observe and what we think produced it.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">AI and new threats</p>
                    <p class="text-sm leading-relaxed">
                      Cruz warns that outsourcing research activities to large language models amplifies the risk of avoidable illusions: LLMs can be useful but cannot think, and their use can undermine the effortful reasoning that genuine understanding requires.
                    </p>
                  </div>

                  <div>
                    <p class="font-sans text-sm font-semibold text-slate-800 dark:text-slate-200 mb-1">Science in public</p>
                    <p class="text-sm leading-relaxed">
                      Fific argues that when science fails to be transparent about its limitations, it becomes difficult for the public to distinguish legitimate findings from conspiracy thinking, and proposes epistemic guardrails as structural protections.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </details>
      </div>
    </Section>
  )}

  <!-- All Resources Grid -->
  <Section background="gray">
    <div class="mx-auto max-w-6xl">
      <ChapterHeader title="All Resources" />

      {otherResources.length > 0 ? (
        <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {otherResources.map((resource) => (
            <a
              href={resource.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group block border border-slate-200 dark:border-slate-700 rounded-xl p-6 bg-white dark:bg-slate-900 transition-all duration-200 hover:border-navy-300 dark:hover:border-navy-600 hover:shadow-md hover:-translate-y-0.5"
            >
              <span class="inline-block font-sans text-[10px] font-medium uppercase text-salmon-600 dark:text-salmon-400 mb-3" style="letter-spacing: 0.2em;">
                {resource.type}
              </span>
              <h3 class="font-serif text-lg text-slate-900 dark:text-white group-hover:text-navy-600 dark:group-hover:text-navy-400 transition-colors" style="line-height: 1.3;">
                {resource.title}
              </h3>
              <div class="mt-2 flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400">
                <span class="font-serif italic">{resource.source}</span>
                <span class="text-slate-300 dark:text-slate-600">&middot;</span>
                <span>{resource.year}</span>
              </div>
              <p class="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400 line-clamp-3">
                {resource.description}
              </p>
            </a>
          ))}
        </div>
      ) : (
        <p class="mt-12 font-serif text-lg italic text-slate-500 dark:text-slate-400">
          More resources coming soon. Submit yours below.
        </p>
      )}
    </div>
  </Section>

  <!-- Contribute CTA -->
  <Section background="white" centered>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold text-slate-900 dark:text-white">
        Contribute a Resource
      </h2>
      <p class="mt-4 text-slate-600 dark:text-slate-400">
        Have a tutorial, tool, or paper to share? We welcome contributions from
        the TMM community.
      </p>
      <div class="mt-6">
        <button id="open-modal-btn" class="btn-primary">
          Submit a Resource
        </button>
      </div>
    </div>
  </Section>

  <!-- Modal -->
  <div
    id="resource-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-black/50 p-4"
  >
    <div class="relative w-full max-w-lg rounded-xl bg-white p-6 shadow-2xl dark:bg-slate-900 my-8">
      <button
        id="close-modal-btn"
        class="absolute right-4 top-4 text-slate-400 hover:text-slate-600 dark:hover:text-slate-300"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <h2 class="text-xl font-semibold text-slate-900 dark:text-white">
        Submit a Resource
      </h2>
      <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
        Share a resource with the TMM community.
      </p>

      <form
        action={`https://formspree.io/f/${FORMSPREE_ID}`}
        method="POST"
        enctype="multipart/form-data"
        class="mt-6 space-y-4"
      >
        <input type="hidden" name="_subject" value="New Resource Submission" />

        <div>
          <label for="name" class="label">Your Name *</label>
          <input type="text" id="name" name="name" required class="input" placeholder="Your name" />
        </div>

        <div>
          <label for="email" class="label">Email *</label>
          <input type="email" id="email" name="email" required class="input" placeholder="your@email.com" />
        </div>

        <div>
          <label for="title" class="label">Resource Title *</label>
          <input type="text" id="title" name="resource_title" required class="input" placeholder="Title of your resource" />
        </div>

        <div>
          <label for="type" class="label">Resource Type *</label>
          <select id="type" name="resource_type" required class="input">
            <option value="">Select type</option>
            {resourceTypes.map((type) => (
              <option value={type}>{type}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="description" class="label">Description *</label>
          <textarea id="description" name="description" required rows="3" class="input" placeholder="Brief description of the resource"></textarea>
        </div>

        <div>
          <label for="url" class="label">URL (optional)</label>
          <input type="url" id="url" name="resource_url" class="input" placeholder="https://..." />
          <p class="mt-1 text-xs text-slate-500">Link to the resource if hosted elsewhere</p>
        </div>

        <div>
          <label for="file" class="label">Upload File (optional)</label>
          <input
            type="file"
            id="file"
            name="attachment"
            class="block w-full text-sm text-slate-600 dark:text-slate-400
              file:mr-4 file:py-2 file:px-4
              file:rounded-lg file:border-0
              file:text-sm file:font-semibold
              file:bg-navy-100 file:text-navy-700
              hover:file:bg-navy-200
              dark:file:bg-navy-900/50 dark:file:text-navy-300"
          />
          <p class="mt-1 text-xs text-slate-500">Max 10MB. PDF, DOC, PPT, or ZIP files.</p>
        </div>

        <div class="pt-2">
          <button type="submit" class="btn-primary w-full">
            Submit Resource
          </button>
        </div>
      </form>
    </div>
  </div>
</PageLayout>

<script>
  const modal = document.getElementById('resource-modal');
  const openBtn = document.getElementById('open-modal-btn');
  const closeBtn = document.getElementById('close-modal-btn');

  function openModal() {
    modal?.classList.remove('hidden');
    modal?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) closeModal();
  });
</script>
