---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import { illusions } from "../../data/collections";
---

<PageLayout
  title="Illusions of Understanding in the Sciences"
  description="A discussion collection on the predictable illusions scientists operate under when interpreting data and building theories."
  subtitle="A target article and cross-disciplinary commentaries on understanding in science."
  eyebrow="Discussion Collection"
  compact
>
  <Section background="white" compactTop>
    <div class="mx-auto max-w-3xl">
      <a href="/resources" class="inline-flex items-center gap-1.5 font-sans text-sm text-slate-500 transition-colors hover:text-salmon-600 dark:text-slate-400 dark:hover:text-salmon-400">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m0 0 5.5 5.5M5 12l5.5-5.5" /></svg>
        Resources
      </a>

      <!-- Meta -->
      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-1">
        <span class="font-serif text-sm italic text-navy-600 dark:text-navy-400">{illusions.source}</span>
        <span class="text-slate-300 dark:text-slate-600">&middot;</span>
        <span class="font-sans text-sm text-slate-500 dark:text-slate-400">{illusions.year}</span>
      </div>

      <!-- Description -->
      <p class="mt-5 text-base leading-relaxed text-slate-600 dark:text-slate-400">
        {illusions.description}
      </p>

      <!-- Links -->
      <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
        <a href={illusions.url} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-1.5 font-sans text-sm font-semibold text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400">
          Read target article
          <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </a>
        <a href={illusions.collectionUrl} target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-1.5 font-sans text-sm font-semibold text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400">
          Browse commentaries
          <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
        </a>
      </div>

      {illusions.memberPapers.length > 0 && (
        <div class="mt-10 border-t border-slate-200 pt-6 dark:border-slate-700">
          <p class="mb-4 font-sans text-[10px] font-semibold uppercase text-slate-400 dark:text-slate-500" style="letter-spacing: 0.2em;">
            TMM Member Contributions
          </p>
          <div class="space-y-4">
            {illusions.memberPapers.map((paper) => (
              <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener noreferrer" class="group block">
                <p class="font-serif text-[15px] text-slate-800 transition-colors group-hover:text-navy-600 dark:text-slate-200 dark:group-hover:text-navy-400" style="line-height: 1.4;">
                  {paper.title}
                </p>
                <p class="mt-1 text-xs text-slate-500 dark:text-slate-400">
                  {paper.authors}
                  <span class="mx-1 text-slate-300 dark:text-slate-600">&middot;</span>
                  <span class="font-serif italic">{paper.venue}</span>
                  <span class="mx-1 text-slate-300 dark:text-slate-600">&middot;</span>
                  {paper.year}
                </p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </Section>
</PageLayout>
