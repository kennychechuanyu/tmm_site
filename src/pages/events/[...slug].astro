---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formatDate = (date?: Date, endDate?: Date) => {
  if (!date) return "Date to be announced";
  const options: Intl.DateTimeFormatOptions = {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  };
  const start = date.toLocaleDateString("en-US", options);
  if (endDate) {
    const end = endDate.toLocaleDateString("en-US", options);
    return `${start} – ${end}`;
  }
  return start;
};

const eventTypeLabel =
  event.data.type.charAt(0).toUpperCase() + event.data.type.slice(1);
const eyebrow = event.data.featured
  ? `${eventTypeLabel} · Featured`
  : eventTypeLabel;

// Combine speakers and panelists for shared rendering
const hasPeople = (event.data.speakers?.length || 0) + (event.data.panelists?.length || 0) > 0;

// Person card renderer helper — used for both speakers and panelists
---

<PageLayout
  title={event.data.title}
  description={event.data.description}
  eyebrow={eyebrow}
  compact
>
  <!-- ─── I. When & Where ─────────────────────────────────────────── -->
  <section class="border-b border-slate-900/10 dark:border-slate-100/10 bg-white dark:bg-slate-950">
    <div class="container-wide py-10">
      <dl class="flex flex-wrap items-baseline gap-x-12 gap-y-5">
        <div class="flex flex-col gap-1.5">
          <dt class="font-sans text-[10px] font-medium uppercase text-slate-400 dark:text-slate-500" style="letter-spacing: 0.22em;">
            When
          </dt>
          <dd class="font-serif text-lg text-slate-900 dark:text-slate-100">
            {formatDate(event.data.date, event.data.endDate)}
          </dd>
        </div>
        <div class="flex flex-col gap-1.5">
          <dt class="font-sans text-[10px] font-medium uppercase text-slate-400 dark:text-slate-500" style="letter-spacing: 0.22em;">
            Where
          </dt>
          <dd class="font-serif text-lg text-slate-900 dark:text-slate-100">
            {event.data.location}
          </dd>
        </div>
        {event.data.registrationUrl && (
          <div class="ml-auto self-center">
            <Button href={event.data.registrationUrl} external>
              Register Now
            </Button>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- ─── II. About ───────────────────────────────────────────────── -->
  {event.data.about && (
    <Section background="white">
      <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            About This Event
          </p>
        </div>

        <p class="font-serif text-xl text-slate-700 dark:text-slate-300 leading-relaxed italic" style="text-indent: 1.5em;">
          {event.data.about}
        </p>

        {event.data.questions && event.data.questions.length > 0 && (
          <div class="mt-10 space-y-0 divide-y divide-slate-200 dark:divide-slate-700 border-y border-slate-200 dark:border-slate-700">
            {event.data.questions.map((q) => (
              <div class="grid gap-2 py-5 md:grid-cols-[140px_1fr] md:gap-8">
                <p class="font-sans text-[11px] font-semibold uppercase text-navy-600 dark:text-navy-400" style="letter-spacing: 0.18em; padding-top: 2px;">
                  {q.label}
                </p>
                <p class="text-[15px] leading-relaxed text-slate-600 dark:text-slate-400">
                  {q.text}
                </p>
              </div>
            ))}
          </div>
        )}
      </div>
    </Section>
  )}

  <!-- ─── III. Speakers ───────────────────────────────────────────── -->
  {event.data.speakers && event.data.speakers.length > 0 && (
    <Section background="gray">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-4 mb-12">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            Speakers
          </p>
        </div>

        <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
          {event.data.speakers.map((person) => (
            <article class="group relative flex flex-col items-center pt-8 text-center">
              <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
              <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>

              <div class="relative">
                {person.photo ? (
                  <img src={person.photo} alt={person.name} class="h-32 w-32 rounded-full object-cover shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 transition-shadow duration-500 group-hover:shadow-xl group-hover:shadow-salmon-100/30 dark:group-hover:shadow-salmon-900/20" />
                ) : (
                  <div class="flex h-32 w-32 rounded-full items-center justify-center bg-slate-50 dark:bg-slate-800 shadow-lg">
                    <span class="font-serif text-2xl text-slate-300 dark:text-slate-600">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                  </div>
                )}
                <div class="absolute -inset-2 rounded-full border border-slate-200/60 dark:border-slate-700/60 transition-colors duration-500 group-hover:border-salmon-300/40 dark:group-hover:border-salmon-600/30" aria-hidden="true"></div>
              </div>

              <h3 class="mt-6 font-serif text-lg text-slate-900 dark:text-white" style="letter-spacing: -0.01em;">{person.name}</h3>
              <div class="mt-2.5 h-px w-6 bg-salmon-400/60 mx-auto"></div>
              <p class="mt-2.5 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
              {person.role && (
                <p class="mt-1 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
              )}

              {person.bio && (
                <details class="bio-accordion mt-5 w-full text-left">
                  <summary class="cursor-pointer select-none py-3 text-center font-sans text-[10px] font-semibold uppercase text-slate-400 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400" style="letter-spacing: 0.2em;">
                    <span class="bio-toggle-label">About</span>
                  </summary>
                  <div class="bio-content">
                    <div class="overflow-hidden">
                      <p class="pb-2 text-[13px] leading-[1.75] text-slate-500 dark:text-slate-400 text-justify">{person.bio}</p>
                    </div>
                  </div>
                </details>
              )}

              {person.website && (
                <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 font-sans text-[11px] font-medium text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                  <span>Personal page</span>
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- ─── IV. Discussion Panel ────────────────────────────────────── -->
  {event.data.panelists && event.data.panelists.length > 0 && (
    <Section background="white">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-4 mb-12">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            Discussion Panel
          </p>
        </div>

        <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
          {event.data.panelists.map((person) => (
            <article class="group relative flex flex-col items-center pt-8 text-center">
              <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
              <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>

              <div class="relative">
                {person.photo ? (
                  <img src={person.photo} alt={person.name} class="h-32 w-32 rounded-full object-cover shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 transition-shadow duration-500 group-hover:shadow-xl group-hover:shadow-salmon-100/30 dark:group-hover:shadow-salmon-900/20" />
                ) : (
                  <div class="flex h-32 w-32 rounded-full items-center justify-center bg-slate-50 dark:bg-slate-800 shadow-lg">
                    <span class="font-serif text-2xl text-slate-300 dark:text-slate-600">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                  </div>
                )}
                <div class="absolute -inset-2 rounded-full border border-slate-200/60 dark:border-slate-700/60 transition-colors duration-500 group-hover:border-salmon-300/40 dark:group-hover:border-salmon-600/30" aria-hidden="true"></div>
              </div>

              <h3 class="mt-6 font-serif text-lg text-slate-900 dark:text-white" style="letter-spacing: -0.01em;">{person.name}</h3>
              <div class="mt-2.5 h-px w-6 bg-salmon-400/60 mx-auto"></div>
              <p class="mt-2.5 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
              {person.role && (
                <p class="mt-1 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
              )}

              {person.bio && (
                <details class="bio-accordion mt-5 w-full text-left">
                  <summary class="cursor-pointer select-none py-3 text-center font-sans text-[10px] font-semibold uppercase text-slate-400 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400" style="letter-spacing: 0.2em;">
                    <span class="bio-toggle-label">About</span>
                  </summary>
                  <div class="bio-content">
                    <div class="overflow-hidden">
                      <p class="pb-2 text-[13px] leading-[1.75] text-slate-500 dark:text-slate-400 text-justify">{person.bio}</p>
                    </div>
                  </div>
                </details>
              )}

              {person.website && (
                <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 font-sans text-[11px] font-medium text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                  <span>Personal page</span>
                  <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- ─── V. Programme, Attendance & Details ───────────────────────── -->
  <Section background="gray">
    <div class="mx-auto max-w-3xl">
      <div class="prose-tmm">
        <Content />
      </div>
    </div>
  </Section>

  <!-- ─── Back ────────────────────────────────────────────────────── -->
  <Section background="white">
    <div class="text-center">
      <Button href="/events" variant="secondary">
        &larr; Back to All Events
      </Button>
    </div>
  </Section>
</PageLayout>
