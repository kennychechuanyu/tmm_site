---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formatDate = (date?: Date, endDate?: Date) => {
  if (!date) return "Date to be determined";
  const options: Intl.DateTimeFormatOptions = {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  };

  const start = date.toLocaleDateString("en-US", options);
  if (endDate) {
    const end = endDate.toLocaleDateString("en-US", options);
    return `${start} - ${end}`;
  }
  return start;
};

const eventTypeLabel =
  event.data.type.charAt(0).toUpperCase() + event.data.type.slice(1);
const eyebrow = event.data.featured
  ? `${eventTypeLabel} · Featured`
  : eventTypeLabel;
---

<PageLayout
  title={event.data.title}
  description={event.data.description}
  eyebrow={eyebrow}
  compact
>
  <!-- Event Meta Strip -->
  <section class="border-b border-slate-900/10 bg-white py-8 dark:border-slate-100/10 dark:bg-slate-950">
    <div class="container-wide">
      <dl
        class="flex flex-wrap items-baseline gap-x-10 gap-y-4 font-sans text-sm text-slate-700 dark:text-slate-300"
      >
        <div class="flex flex-col gap-1">
          <dt
            class="font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
            style="letter-spacing: 0.22em;"
          >
            When
          </dt>
          <dd class="font-serif text-base text-slate-900 dark:text-slate-100 md:text-lg">
            {formatDate(event.data.date, event.data.endDate)}
          </dd>
        </div>

        <div class="flex flex-col gap-1">
          <dt
            class="font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
            style="letter-spacing: 0.22em;"
          >
            Where
          </dt>
          <dd class="font-serif text-base text-slate-900 dark:text-slate-100 md:text-lg">
            {event.data.location}
          </dd>
        </div>

        {event.data.registrationUrl && (
          <div class="ml-auto self-center">
            <Button href={event.data.registrationUrl} external>
              Register Now
            </Button>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- Speakers & Panel -->
  {((event.data.speakers && event.data.speakers.length > 0) || (event.data.panelists && event.data.panelists.length > 0)) && (
    <Section background="white">
      <div class="mx-auto max-w-5xl">
        {event.data.speakers && event.data.speakers.length > 0 && (
          <div>
            <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400 mb-10" style="letter-spacing: 0.22em;">
              Speakers
            </p>
            <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {event.data.speakers.map((person) => (
                <article class="group relative flex flex-col items-center pt-8 text-center">
                  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
                  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>
                  {person.photo ? (
                    <img src={person.photo} alt={person.name} class="h-24 w-24 rounded-full object-cover ring-2 ring-slate-100 dark:ring-slate-700" />
                  ) : (
                    <div class="flex h-24 w-24 rounded-full items-center justify-center bg-slate-100 dark:bg-slate-800 ring-2 ring-slate-100 dark:ring-slate-700">
                      <span class="font-serif text-xl text-slate-400 dark:text-slate-500">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                    </div>
                  )}
                  <h3 class="mt-4 font-serif text-lg text-slate-900 dark:text-white">{person.name}</h3>
                  <p class="mt-1 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
                  {person.role && (
                    <p class="mt-0.5 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
                  )}
                  {person.bio && (
                    <details class="mt-4 w-full text-left">
                      <summary class="cursor-pointer select-none border-t border-slate-200 pt-3 text-center font-sans text-xs font-medium uppercase text-navy-600 transition-colors hover:text-salmon-600 dark:border-slate-700 dark:text-navy-400 dark:hover:text-salmon-400" style="letter-spacing: 0.15em;">
                        <span class="bio-toggle-label">About</span>
                      </summary>
                      <div class="bio-content">
                        <div class="overflow-hidden">
                          <p class="pt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400 text-justify">{person.bio}</p>
                        </div>
                      </div>
                    </details>
                  )}
                  {person.website && (
                    <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 font-sans text-xs text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                      Personal page &rarr;
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        )}

        {event.data.panelists && event.data.panelists.length > 0 && (
          <div class:list={[event.data.speakers && event.data.speakers.length > 0 && "mt-20"]}>
            <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400 mb-10" style="letter-spacing: 0.22em;">
              Discussion Panel
            </p>
            <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
              {event.data.panelists.map((person) => (
                <article class="group relative flex flex-col items-center pt-8 text-center">
                  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
                  <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>
                  {person.photo ? (
                    <img src={person.photo} alt={person.name} class="h-24 w-24 rounded-full object-cover ring-2 ring-slate-100 dark:ring-slate-700" />
                  ) : (
                    <div class="flex h-24 w-24 rounded-full items-center justify-center bg-slate-100 dark:bg-slate-800 ring-2 ring-slate-100 dark:ring-slate-700">
                      <span class="font-serif text-xl text-slate-400 dark:text-slate-500">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                    </div>
                  )}
                  <h3 class="mt-4 font-serif text-lg text-slate-900 dark:text-white">{person.name}</h3>
                  <p class="mt-1 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
                  {person.role && (
                    <p class="mt-0.5 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
                  )}
                  {person.bio && (
                    <details class="mt-4 w-full text-left">
                      <summary class="cursor-pointer select-none border-t border-slate-200 pt-3 text-center font-sans text-xs font-medium uppercase text-navy-600 transition-colors hover:text-salmon-600 dark:border-slate-700 dark:text-navy-400 dark:hover:text-salmon-400" style="letter-spacing: 0.15em;">
                        <span class="bio-toggle-label">About</span>
                      </summary>
                      <div class="bio-content">
                        <div class="overflow-hidden">
                          <p class="pt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400 text-justify">{person.bio}</p>
                        </div>
                      </div>
                    </details>
                  )}
                  {person.website && (
                    <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 font-sans text-xs text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                      Personal page &rarr;
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        )}
      </div>
    </Section>
  )}

  <!-- Event Content -->
  <Section background="white">
    <div class="mx-auto max-w-3xl">
      <div class="prose-tmm">
        <Content />
      </div>
    </div>
  </Section>

  <!-- Back Link -->
  <Section background="gray">
    <div class="text-center">
      <Button href="/events" variant="secondary">
        &larr; Back to All Events
      </Button>
    </div>
  </Section>
</PageLayout>
