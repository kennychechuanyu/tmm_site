---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formatDate = (date?: Date, endDate?: Date) => {
  if (!date) return "Date to be determined";
  const options: Intl.DateTimeFormatOptions = {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  };

  const start = date.toLocaleDateString("en-US", options);
  if (endDate) {
    const end = endDate.toLocaleDateString("en-US", options);
    return `${start} - ${end}`;
  }
  return start;
};

const eventTypeLabel =
  event.data.type.charAt(0).toUpperCase() + event.data.type.slice(1);
const eyebrow = event.data.featured
  ? `${eventTypeLabel} · Featured`
  : eventTypeLabel;
---

<PageLayout
  title={event.data.title}
  description={event.data.description}
  eyebrow={eyebrow}
  compact
>
  <!-- Event Meta Strip -->
  <section class="border-b border-slate-900/10 bg-white py-8 dark:border-slate-100/10 dark:bg-slate-950">
    <div class="container-wide">
      <dl
        class="flex flex-wrap items-baseline gap-x-10 gap-y-4 font-sans text-sm text-slate-700 dark:text-slate-300"
      >
        <div class="flex flex-col gap-1">
          <dt
            class="font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
            style="letter-spacing: 0.22em;"
          >
            When
          </dt>
          <dd class="font-serif text-base text-slate-900 dark:text-slate-100 md:text-lg">
            {formatDate(event.data.date, event.data.endDate)}
          </dd>
        </div>

        <div class="flex flex-col gap-1">
          <dt
            class="font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
            style="letter-spacing: 0.22em;"
          >
            Where
          </dt>
          <dd class="font-serif text-base text-slate-900 dark:text-slate-100 md:text-lg">
            {event.data.location}
          </dd>
        </div>

        {event.data.registrationUrl && (
          <div class="ml-auto self-center">
            <Button href={event.data.registrationUrl} external>
              Register Now
            </Button>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- Speakers & Panel -->
  {((event.data.speakers && event.data.speakers.length > 0) || (event.data.panelists && event.data.panelists.length > 0)) && (
    <Section background="white">
      <div class="mx-auto max-w-5xl">
        {event.data.speakers && event.data.speakers.length > 0 && (
          <div>
            <div class="flex items-center gap-4 mb-12">
              <span class="inline-block h-px w-10 bg-salmon-500"></span>
              <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
                Speakers
              </p>
            </div>
            <div class="grid grid-cols-1 gap-y-16 sm:grid-cols-2">
              {event.data.speakers.map((person) => (
                <article class="group flex flex-col items-center text-center px-8">
                  <!-- Photo with layered ring effect -->
                  <div class="relative">
                    {person.photo ? (
                      <img src={person.photo} alt={person.name} class="h-36 w-36 rounded-full object-cover shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 transition-shadow duration-500 group-hover:shadow-xl group-hover:shadow-salmon-100/30 dark:group-hover:shadow-salmon-900/20" />
                    ) : (
                      <div class="flex h-36 w-36 rounded-full items-center justify-center bg-slate-50 dark:bg-slate-800 shadow-lg">
                        <span class="font-serif text-3xl text-slate-300 dark:text-slate-600">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                      </div>
                    )}
                    <div class="absolute -inset-2 rounded-full border border-slate-200/60 dark:border-slate-700/60 transition-colors duration-500 group-hover:border-salmon-300/40 dark:group-hover:border-salmon-600/30" aria-hidden="true"></div>
                  </div>

                  <!-- Name with decorative rule -->
                  <h3 class="mt-7 font-serif text-xl text-slate-900 dark:text-white" style="letter-spacing: -0.01em;">{person.name}</h3>
                  <div class="mt-3 h-px w-8 bg-salmon-400/60 mx-auto"></div>

                  <!-- Affiliation -->
                  <p class="mt-3 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
                  {person.role && (
                    <p class="mt-1 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
                  )}

                  <!-- Bio accordion -->
                  {person.bio && (
                    <details class="bio-accordion mt-5 w-full text-left">
                      <summary class="cursor-pointer select-none py-3 text-center font-sans text-[10px] font-semibold uppercase text-slate-400 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400" style="letter-spacing: 0.2em;">
                        <span class="bio-toggle-label">About</span>
                      </summary>
                      <div class="bio-content">
                        <div class="overflow-hidden">
                          <p class="pb-2 text-[13px] leading-[1.75] text-slate-500 dark:text-slate-400 text-justify">{person.bio}</p>
                        </div>
                      </div>
                    </details>
                  )}

                  <!-- Website -->
                  {person.website && (
                    <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 font-sans text-[11px] font-medium text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                      <span>Homepage</span>
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        )}

        {event.data.panelists && event.data.panelists.length > 0 && (
          <div class:list={[event.data.speakers && event.data.speakers.length > 0 && "mt-24 pt-16 border-t border-slate-200 dark:border-slate-700"]}>
            <div class="flex items-center gap-4 mb-12">
              <span class="inline-block h-px w-10 bg-salmon-500"></span>
              <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
                Discussion Panel
              </p>
            </div>
            <div class="grid grid-cols-1 gap-y-16 sm:grid-cols-2 lg:grid-cols-4">
              {event.data.panelists.map((person) => (
                <article class="group flex flex-col items-center text-center px-4">
                  <!-- Photo -->
                  <div class="relative">
                    {person.photo ? (
                      <img src={person.photo} alt={person.name} class="h-28 w-28 rounded-full object-cover shadow-lg shadow-slate-200/50 dark:shadow-slate-900/50 transition-shadow duration-500 group-hover:shadow-xl group-hover:shadow-salmon-100/30 dark:group-hover:shadow-salmon-900/20" />
                    ) : (
                      <div class="flex h-28 w-28 rounded-full items-center justify-center bg-slate-50 dark:bg-slate-800 shadow-lg">
                        <span class="font-serif text-2xl text-slate-300 dark:text-slate-600">{person.name.split(" ").map((n: string) => n[0]).join("")}</span>
                      </div>
                    )}
                    <div class="absolute -inset-2 rounded-full border border-slate-200/60 dark:border-slate-700/60 transition-colors duration-500 group-hover:border-salmon-300/40 dark:group-hover:border-salmon-600/30" aria-hidden="true"></div>
                  </div>

                  <!-- Name with decorative rule -->
                  <h3 class="mt-6 font-serif text-lg text-slate-900 dark:text-white" style="letter-spacing: -0.01em;">{person.name}</h3>
                  <div class="mt-2.5 h-px w-6 bg-salmon-400/60 mx-auto"></div>

                  <!-- Affiliation -->
                  <p class="mt-2.5 text-sm font-medium text-navy-600 dark:text-navy-400">{person.institution}</p>
                  {person.role && (
                    <p class="mt-1 font-serif text-xs italic text-slate-500 dark:text-slate-400">{person.role}</p>
                  )}

                  <!-- Bio accordion -->
                  {person.bio && (
                    <details class="bio-accordion mt-4 w-full text-left">
                      <summary class="cursor-pointer select-none py-3 text-center font-sans text-[10px] font-semibold uppercase text-slate-400 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400" style="letter-spacing: 0.2em;">
                        <span class="bio-toggle-label">About</span>
                      </summary>
                      <div class="bio-content">
                        <div class="overflow-hidden">
                          <p class="pb-2 text-[13px] leading-[1.75] text-slate-500 dark:text-slate-400 text-justify">{person.bio}</p>
                        </div>
                      </div>
                    </details>
                  )}

                  <!-- Website -->
                  {person.website && (
                    <a href={person.website} target="_blank" rel="noopener noreferrer" class="mt-3 inline-flex items-center gap-1.5 font-sans text-[11px] font-medium text-navy-600 hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400 transition-colors">
                      <span>Homepage</span>
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" /></svg>
                    </a>
                  )}
                </article>
              ))}
            </div>
          </div>
        )}
      </div>
    </Section>
  )}

  <!-- Event Content -->
  <Section background="white">
    <div class="mx-auto max-w-3xl">
      <div class="prose-tmm">
        <Content />
      </div>
    </div>
  </Section>

  <!-- Back Link -->
  <Section background="gray">
    <div class="text-center">
      <Button href="/events" variant="secondary">
        &larr; Back to All Events
      </Button>
    </div>
  </Section>
</PageLayout>
