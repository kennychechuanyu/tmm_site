---
import PageLayout from "../../layouts/PageLayout.astro";
import Section from "../../components/Section.astro";
import Button from "../../components/Button.astro";
import PersonCard from "../../components/PersonCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const events = await getCollection("events");
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const formatDate = (date?: Date, endDate?: Date) => {
  if (!date) return "Date to be announced";
  const options: Intl.DateTimeFormatOptions = {
    weekday: "long",
    month: "long",
    day: "numeric",
    year: "numeric",
  };
  const start = date.toLocaleDateString("en-US", options);
  if (endDate) {
    const end = endDate.toLocaleDateString("en-US", options);
    return `${start} – ${end}`;
  }
  return start;
};

const eventTypeLabel =
  event.data.type.charAt(0).toUpperCase() + event.data.type.slice(1);
const eyebrow = event.data.featured
  ? `${eventTypeLabel} · Featured`
  : eventTypeLabel;

// Combine speakers and panelists for shared rendering
const hasPeople = (event.data.speakers?.length || 0) + (event.data.panelists?.length || 0) > 0;

// Order people by last name, keeping unconfirmed placeholders at the end
const byLastName = (a: { name: string }, b: { name: string }) => {
  const aTBC = a.name === "To Be Confirmed";
  const bTBC = b.name === "To Be Confirmed";
  if (aTBC !== bTBC) return aTBC ? 1 : -1;
  return a.name.split(" ").pop()!.localeCompare(b.name.split(" ").pop()!);
};
const sortedSpeakers = [...(event.data.speakers ?? [])].sort(byLastName);
const sortedPanelists = [...(event.data.panelists ?? [])].sort(byLastName);
---

<PageLayout
  title={event.data.title}
  description={event.data.description}
  eyebrow={eyebrow}
  compact
>
  <!-- ─── I. When & Where ─────────────────────────────────────────── -->
  <section class="border-b border-slate-900/10 dark:border-slate-100/10 bg-white dark:bg-slate-950">
    <div class="container-wide py-10">
      <dl class="flex flex-wrap items-baseline gap-x-12 gap-y-5">
        <div class="flex flex-col gap-1.5">
          <dt class="font-sans text-[10px] font-medium uppercase text-slate-400 dark:text-slate-500" style="letter-spacing: 0.22em;">
            When
          </dt>
          <dd class="font-serif text-lg text-slate-900 dark:text-slate-100">
            {formatDate(event.data.date, event.data.endDate)}
          </dd>
        </div>
        <div class="flex flex-col gap-1.5">
          <dt class="font-sans text-[10px] font-medium uppercase text-slate-400 dark:text-slate-500" style="letter-spacing: 0.22em;">
            Where
          </dt>
          <dd class="font-serif text-lg text-slate-900 dark:text-slate-100">
            {event.data.location}
          </dd>
        </div>
        {event.data.registrationUrl && (
          <div class="ml-auto self-center">
            <Button href={event.data.registrationUrl} external>
              Register Now
            </Button>
          </div>
        )}
      </dl>
    </div>
  </section>

  <!-- ─── II. About ───────────────────────────────────────────────── -->
  {event.data.about && (
    <Section background="white">
      <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-4 mb-8">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            About This Event
          </p>
        </div>

        <p class="font-serif text-xl text-slate-700 dark:text-slate-300 leading-relaxed italic" style="text-indent: 1.5em;">
          {event.data.about}
        </p>

        {event.data.questions && event.data.questions.length > 0 && (
          <div class="mt-10 space-y-0 divide-y divide-slate-200 dark:divide-slate-700 border-y border-slate-200 dark:border-slate-700">
            {event.data.questions.map((q) => (
              <div class="grid gap-2 py-5 md:grid-cols-[140px_1fr] md:gap-8">
                <p class="font-sans text-[11px] font-semibold uppercase text-navy-600 dark:text-navy-400" style="letter-spacing: 0.18em; padding-top: 2px;">
                  {q.label}
                </p>
                <p class="text-[15px] leading-relaxed text-slate-600 dark:text-slate-400">
                  {q.text}
                </p>
              </div>
            ))}
          </div>
        )}
      </div>
    </Section>
  )}

  <!-- ─── III. Speakers ───────────────────────────────────────────── -->
  {event.data.speakers && event.data.speakers.length > 0 && (
    <Section background="gray">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-4 mb-12">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            Speakers
          </p>
        </div>

        <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
          {sortedSpeakers.map((person) => (
            <PersonCard
              name={person.name}
              institution={person.institution}
              role={person.role}
              image={person.photo}
              website={person.website}
              bio={person.bio}
            />
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- ─── IV. Discussion Panel ────────────────────────────────────── -->
  {event.data.panelists && event.data.panelists.length > 0 && (
    <Section background="white">
      <div class="mx-auto max-w-5xl">
        <div class="flex items-center gap-4 mb-12">
          <span class="inline-block h-px w-10 bg-salmon-500"></span>
          <p class="font-sans text-[11px] font-medium uppercase text-salmon-600 dark:text-salmon-400" style="letter-spacing: 0.22em;">
            Discussion Panel
          </p>
        </div>

        <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
          {sortedPanelists.map((person) => (
            <PersonCard
              name={person.name}
              institution={person.institution}
              role={person.role}
              image={person.photo}
              website={person.website}
              bio={person.bio}
            />
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- ─── V. Programme, Attendance & Details ───────────────────────── -->
  <Section background="gray">
    <div class="mx-auto max-w-3xl">
      <div class="prose-tmm">
        <Content />
      </div>
    </div>
  </Section>

  <!-- ─── Back ────────────────────────────────────────────────────── -->
  <Section background="white">
    <div class="text-center">
      <Button href="/events" variant="secondary">
        &larr; Back to All Events
      </Button>
    </div>
  </Section>
</PageLayout>
