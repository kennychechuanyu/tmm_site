---
import PageLayout from "../layouts/PageLayout.astro";
import Section from "../components/Section.astro";
import ChapterHeader from "../components/ChapterHeader.astro";

const sortByName = (a: { name: string }, b: { name: string }) =>
  a.name.split(" ").pop()!.localeCompare(b.name.split(" ").pop()!);

// Coordinating Team members
const coordinatingCommittee = [
  {
    name: "Dr. Maria Robinson",
    role: "Behavioural Science Group",
    institution: "University of Warwick",
    email: "maria.robinson@warwick.ac.uk",
    image: "/images/people/MR.png",
    bio: "Maria Robinson is an assistant professor in the Behavioral Science group in the Psychology Department at the University of Warwick. She received her PhD at the University of Illinois Urbana-Champaign in 2019 and was an NRSA postdoc in Timothy Brady's lab at the University of California, San Diego. Her primary research interest is in combining formal modeling and analysis with empirical work to study a range of cognitive processes, like attention and memory. She is also interested in topics on best practices in measurement and theory assessment in psychology.",
    website: "https://mrobinson93.github.io/",
  },
  {
    name: "Dr. Niels Vanhasbroeck",
    role: "Psychological Methods",
    institution: "University of Amsterdam",
    email: "n.d.p.vanhasbroeck@uva.nl",
    image: "/images/people/NV.jpg",
    bio: "Niels Vanhasbroeck is a mathematical psychologist with a special interest in (non)linear models capturing psychological processes such as emotions, attitudes, and pedestrian behavior. He seeks to bridge mathematical models and psychological theory, allowing for the formulation of theory through the language of mathematics and its testing through phenomena generation and direct engagement with data. He furthermore asks what types of psychological phenomena allow for mathematical description and what we learn through this quantification—connecting qualitative phenomena to quantitative measurement.",
    website: "https://ndpvh.github.io",
  },
  {
    name: "Dr. Kenny Yu",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "kenny.yu@kuleuven.be",
    image: "/images/people/KY.jpg",
  },
];

// Network Members
const networkMembers = [
  {
    name: "Dr. Sigert Ariens",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "sigert.ariens@kuleuven.be",
    image: "/images/people/SA.png",
    bio: "Sigert Ariens is a mathematical psychologist focused on the dynamic paradigm in psychological science. His main areas of research are model interpretation, study design, and misspecification. He has developed a framework and software tools to help researchers interpret dynamic model structures and align them with psychological hypotheses, and works on study designs which aim to maximize the amount of information about the dynamic parameters. His work on misspecification criticizes atheoretic methods for handling dependence over time.",
  },
  {
    name: "Prof. Andrew Heathcote",
    role: "Amsterdam Mathematical Psychology Laboratory",
    institution: "University of Amsterdam & University of Newcastle",
    email: "ajheathcote@gmail.com",
    image: "/images/people/AH.png",
    website: "https://www.ampl-psych.com/team/andrew-heathcote/",
    bio: "Andrew Heathcote is a cognitive scientist whose work centres on evidence accumulation models of rapid decision-making. He is known for developing the Linear Ballistic Accumulator (LBA), a widely used model for understanding how people make choices across laboratory, occupational, and clinical settings. His research integrates mathematical modelling with cognitive science to investigate memory, skill acquisition, and decision control across the lifespan.",
  },
  {
    name: "Prof. Adam Sanborn",
    role: "Department of Psychology",
    institution: "University of Warwick",
    email: "adam.n.sanborn@warwick.ac.uk",
    image: "/images/people/AS.jpg",
    website: "https://sampling.warwick.ac.uk",
    website2: "https://profiles.warwick.ac.uk/pssjak-adam-sanborn",
    bio: "Adam Sanborn is a cognitive scientist interested in the rationality of human behaviour, which he studies with Bayesian models, approximations to Bayesian models, and behavioural experiments. He is interested in developing general-purpose models of cognition that can explain why human behaviour broadly corresponds to Bayesian models, yet also show strong deviations.",
  },
];
---

<PageLayout
  title="People"
  description="Meet the researchers behind the TMM network."
  subtitle="Meet the researchers behind TMM"
>
  <!-- Coordinating Team -->
  <Section background="white">
    <div class="mx-auto max-w-6xl">
      <ChapterHeader title="Coordinating Team" />

      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 md:mt-16">
        {coordinatingCommittee.sort(sortByName).map((member) => (
          <article class="group relative flex flex-col items-center pt-8 text-center">
            <!-- Top accent rule -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>

            <img
              src={member.image}
              alt={member.name}
              class="h-32 w-32 rounded-full object-cover ring-2 ring-slate-100 dark:ring-slate-700"
            />
            <h3 class="mt-5 whitespace-nowrap font-serif text-lg text-slate-900 dark:text-white">
              {member.name}
            </h3>
            <p class="mt-1.5 text-sm font-medium text-navy-600 dark:text-navy-400">
              {member.institution}
            </p>
            <p class="mt-1 font-serif text-xs italic text-slate-500 dark:text-slate-400">
              {member.role}
            </p>

            {member.bio && (
              <details class="mt-4 w-full text-left">
                <summary class="cursor-pointer select-none border-t border-slate-200 pt-3 text-center font-sans text-xs font-medium uppercase text-navy-600 transition-colors hover:text-salmon-600 dark:border-slate-700 dark:text-navy-400 dark:hover:text-salmon-400" style="letter-spacing: 0.15em;">
                  <span class="bio-toggle-label">About</span>
                </summary>
                <div class="bio-content">
                  <div class="overflow-hidden">
                    <p class="pt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                      {member.bio}
                    </p>
                  </div>
                </div>
              </details>
            )}

            <div class="mt-4 flex flex-col items-center gap-1.5">
              <a
                href={`mailto:${member.email}`}
                class="font-mono text-xs text-slate-500 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400"
              >
                {member.email}
              </a>
              {member.website && (
                <a
                  href={member.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-xs text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
                >
                  {member.website2 ? "Lab page →" : "Personal page →"}
                </a>
              )}
              {member.website2 && (
                <a
                  href={member.website2}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-xs text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
                >
                  University profile →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </Section>

  <!-- Network Members -->
  <Section background="gray">
    <div class="mx-auto max-w-6xl">
      <ChapterHeader title="Network Members" />

      <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 md:mt-16">
        {networkMembers.sort(sortByName).map((member) => (
          <article class="group relative flex flex-col items-center pt-8 text-center">
            <!-- Top accent rule -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-200 dark:bg-slate-700"></div>
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-[2px] w-0 bg-salmon-500 transition-[width] duration-700 ease-out group-hover:w-full dark:bg-salmon-400"></div>

            <img
              src={member.image}
              alt={member.name}
              class="h-32 w-32 rounded-full object-cover ring-2 ring-slate-100 dark:ring-slate-700"
            />
            <h3 class="mt-5 whitespace-nowrap font-serif text-lg text-slate-900 dark:text-white">
              {member.name}
            </h3>
            <p class="mt-1.5 whitespace-nowrap text-sm font-medium text-navy-600 dark:text-navy-400">
              {member.institution}
            </p>
            <p class="mt-1 whitespace-nowrap font-serif text-xs italic text-slate-500 dark:text-slate-400">
              {member.role}
            </p>

            {member.bio && (
              <details class="mt-4 w-full text-left">
                <summary class="cursor-pointer select-none border-t border-slate-200 pt-3 text-center font-sans text-xs font-medium uppercase text-navy-600 transition-colors hover:text-salmon-600 dark:border-slate-700 dark:text-navy-400 dark:hover:text-salmon-400" style="letter-spacing: 0.15em;">
                  <span class="bio-toggle-label">About</span>
                </summary>
                <div class="bio-content">
                  <div class="overflow-hidden">
                    <p class="pt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-400">
                      {member.bio}
                    </p>
                  </div>
                </div>
              </details>
            )}

            <div class="mt-4 flex flex-col items-center gap-1.5">
              <a
                href={`mailto:${member.email}`}
                class="font-mono text-xs text-slate-500 transition-colors hover:text-salmon-600 dark:text-slate-500 dark:hover:text-salmon-400"
              >
                {member.email}
              </a>
              {member.website && (
                <a
                  href={member.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-xs text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
                >
                  {member.website2 ? "Lab page →" : "Personal page →"}
                </a>
              )}
              {member.website2 && (
                <a
                  href={member.website2}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-sans text-xs text-navy-600 transition-colors hover:text-salmon-600 dark:text-navy-400 dark:hover:text-salmon-400"
                >
                  University profile →
                </a>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </Section>
</PageLayout>
