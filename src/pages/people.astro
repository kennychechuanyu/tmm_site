---
import PageLayout from "../layouts/PageLayout.astro";
import Section from "../components/Section.astro";
import ChapterHeader from "../components/ChapterHeader.astro";
import PersonCard from "../components/PersonCard.astro";

const lastName = (n: string) =>
  n.replace(/\s*\(.*?\)\s*/g, " ").trim().split(" ").pop()!;
const sortByName = (a: { name: string }, b: { name: string }) =>
  lastName(a.name).localeCompare(lastName(b.name));

// Coordinating Team members
const coordinatingCommittee = [
  {
    name: "Maria Robinson",
    role: "Behavioural Science Group",
    institution: "University of Warwick",
    email: "maria.robinson@warwick.ac.uk",
    image: "/images/people/MR.png",
    bio: "Maria Robinson is an assistant professor in the Behavioral Science group in the Psychology Department at the University of Warwick. Her primary research interest is in combining formal modeling and analysis with empirical work to study a range of cognitive processes, including attention, memory, and metacognition. She is also interested in best practices in measurement and theory assessment in psychology, particularly in how to build quantitative models in laboratory settings that can generalize to behavior in the real world.",
    website: "https://mrobinson93.github.io/",
  },
  {
    name: "Niels Vanhasbroeck",
    role: "Psychological Methods",
    institution: "University of Amsterdam",
    email: "n.d.p.vanhasbroeck@uva.nl",
    image: "/images/people/NV.jpg",
    bio: "Niels Vanhasbroeck is a mathematical psychologist with a special interest in (non)linear models capturing psychological processes such as emotions, attitudes, and pedestrian behavior. He seeks to bridge mathematical models and psychological theory, allowing for the formulation of theory through the language of mathematics and its testing through phenomena generation and direct engagement with data. He furthermore asks what types of psychological phenomena allow for mathematical description and what we learn through this quantification—connecting qualitative phenomena to quantitative measurement.",
    website: "https://ndpvh.github.io",
  },
  {
    name: "Kenny Yu",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "kenny.yu@kuleuven.be",
    image: "/images/people/KY.jpg",
    bio: "Kenny Yu is a mathematical psychologist who investigates the conditions under which computational models of cognition live up to their claims \u2014 that behavior can be decomposed into distinct processes, that model parameters correspond to the processes they purport to measure, and that fitting data constitutes evidence for theory. He builds probabilistic models of human learning and generalization that formally separate the cognitive mechanisms contributing to observed behavior. Methodologically, he asks when a model parameter genuinely measures the process it names, what data is needed to tell competing theories apart, and how model generalisability relates to explanatory power.",
  },
];

// Network Members
const networkMembers = [
  {
    name: "Sigert Ariens",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "sigert.ariens@kuleuven.be",
    image: "/images/people/SA.png",
    website: "https://ppw.kuleuven.be/okp/team/Sigert_Ariens/",
    bio: "Sigert Ariens is a mathematical psychologist focused on the dynamic paradigm in psychological science. His main areas of research are model interpretation, study design, and misspecification. He has developed a framework and software tools to help researchers interpret dynamic model structures and align them with psychological hypotheses, and works on study designs which aim to maximize the amount of information about the dynamic parameters. His work on misspecification criticizes atheoretic methods for handling dependence over time.",
  },
  {
    name: "Andrew Heathcote",
    role: "Amsterdam Mathematical Psychology Laboratory",
    institution: "University of Amsterdam & University of Newcastle",
    email: "ajheathcote@gmail.com",
    image: "/images/people/AH.png",
    website: "https://www.ampl-psych.com/team/andrew-heathcote/",
    website2: "https://www.uva.nl/en/profile/h/e/a.j.heathcote/a.j.heathcote.html",
    bio: "Andrew Heathcote is a cognitive scientist whose work centres on evidence accumulation models of rapid decision-making. He is known for developing the Linear Ballistic Accumulator (LBA), a widely used model for understanding how people make choices across laboratory, occupational, and clinical settings. His research integrates mathematical modelling with cognitive science to investigate memory, skill acquisition, and decision control across the lifespan.",
  },
  {
    name: "Francis Tuerlinckx",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "francis.tuerlinckx@kuleuven.be",
    image: "/images/people/FT.jpg",
    website: "https://ppw.kuleuven.be/okp/team/Francis_Tuerlinckx/",
    bio: "Francis Tuerlinckx is a psychometrician and professor of Quantitative Psychology and Individual Differences at KU Leuven in Belgium. His research deals with the mathematical modeling of various aspects of human behavior. More specifically, he works on item response theory, reaction time modeling, and dynamical systems data analysis.",
  },
  {
    name: "Craig Hedge",
    role: "School of Psychology",
    institution: "Aston University",
    email: "c.hedge@aston.ac.uk",
    image: "/images/people/CH.jpg",
    bio: "Craig Hedge is a cognitive psychologist interested in attention control and decision-making. He is particularly interested in whether cognitive modelling improves our ability to predict and explain individual differences in real-world behaviours, relative to traditional behavioural measures.",
  },
  {
    name: "David Kellen",
    role: "Department of Psychology",
    institution: "Syracuse University",
    email: "dkellen@syr.edu",
    image: "/images/people/DK.png",
    website: "https://artsandsciences.syracuse.edu/people/faculty/kellen-phd-david/",
    bio: "David Kellen is a cognitive psychologist and associate professor in the Department of Psychology at Syracuse University. His research focuses on recognition memory, judgment and decision making, and the development and evaluation of formal models in cognitive psychology. Much of this work centers on signal detection theory and probabilistic models of choice.",
  },
  {
    name: "Markus Eronen",
    role: "Department of Theoretical Philosophy",
    institution: "University of Groningen",
    email: "m.i.eronen@rug.nl",
    image: "/images/people/ME.jpg",
    website: "https://www.markuseronen.com",
    bio: "Markus Eronen is an associate professor at the University of Groningen (Department of Theoretical Philosophy), working on philosophy of science and the limits and possibilities of developing psychological theories and causal explanations.",
  },
  {
    name: "Wolf Vanpaemel",
    role: "Quantitative Psychology and Individual Differences",
    institution: "KU Leuven",
    email: "wolf.vanpaemel@kuleuven.be",
    image: "/images/people/WV.jpg",
    website: "https://ppw.kuleuven.be/okp/people/wolf_vanpaemel/",
    bio: "Wolf Vanpaemel is head of the Research Group of Quantitative Psychology and Individual Differences at KU Leuven. His research is situated within mathematical psychology and centers on methodological and metascientific issues, including Bayesian statistics, and the concept of the data prior as a tool for severe theory testing. He recently authored a resource for scrutinizing and replicating studies: Evaluating and replicating studies: A practical guide (available at earsguide.io).",
  },
  {
    name: "Laura Bringmann",
    role: "Department of Psychometrics and Statistics",
    institution: "University of Groningen",
    email: "l.f.bringmann@rug.nl",
    image: "/images/people/LB.png",
    website: "https://www.laurabringmannlab.com/",
    bio: "Laura Bringmann is an associate professor at the Department of Psychometrics and Statistics at the University of Groningen, and heads the LaBlab (Laura Bringmann's intensive longitudinal data lab). Her research focuses on bridging the gap between fields such as statistics, philosophy, methodology, and clinical psychology.",
  },
  {
    name: "Adam Sanborn",
    role: "Behavioural Science Group",
    institution: "University of Warwick",
    email: "adam.n.sanborn@warwick.ac.uk",
    image: "/images/people/AS.jpg",
    website: "https://sampling.warwick.ac.uk",
    website2: "https://profiles.warwick.ac.uk/pssjak-adam-sanborn",
    bio: "Adam Sanborn is a cognitive scientist interested in the rationality of human behaviour, which he studies with Bayesian models, approximations to Bayesian models, and behavioural experiments. He is interested in developing general-purpose models of cognition that can explain why human behaviour broadly corresponds to Bayesian models, yet also show strong deviations.",
  },
  {
    name: "Marina Dubova",
    role: "Cognitive Epistemology Lab",
    institution: "UC Berkeley",
    email: "mdubova@santafe.edu",
    image: "/images/people/MD.jpg",
    website: "https://www.mdubova.com/",
    bio: "Marina Dubova is an assistant professor at UC Berkeley, where she directs the Cognitive Epistemology Lab. She studies the cognitive mechanisms of scientific discovery, using computational modeling and empirical work with scientists to understand how we actually observe and build theories about the world, and how we ought to.",
  },
  {
    name: "Andrew Perfors (Andy)",
    role: "Complex Human Data Hub",
    institution: "University of Melbourne",
    email: "andrew.perfors@unimelb.edu.au",
    image: "/images/people/AP.jpg",
    website: "https://findanexpert.unimelb.edu.au/profile/800124-andrew-perfors",
    bio: "Andrew Perfors is the Director of the Complex Human Data Hub in the School of Psychological Sciences at the University of Melbourne. He uses computational models of the mind, in combination with behavioural experiments, to study human cognition: how we acquire and use concepts and language, how we make decisions, how we learn from and share information with each other, and how that process of collaborative meaning-making changes the information environment itself. Andy has many thoughts about the role of models and computation in cognitive science, not just in terms of epistemology (what do they tell us, and how can they best be used?) but also given the real-world incentives and power structures that science is embedded in.",
  },
  {
    name: "Marie-Ann Sengewald",
    role: "Department of Psychology",
    institution: "FAU Erlangen-Nürnberg",
    email: "marie.sengewald@fau.de",
    image: "/images/people/MAS.jpg",
    website: "https://www.methodenlehre.phil.fau.de/en/",
    website2: "https://www.m-sengewald.de/",
    bio: "Marie-Ann Sengewald is an assistant professor at Friedrich-Alexander-Universität (FAU) Erlangen-Nürnberg and a research associate at the Leibniz Institute for Educational Trajectories (LIfBi). Her research advances quantitative methods in psychometrics, causal inference, and metascience. She is particularly interested in developing methodological approaches that help researchers strengthen scientific evidence by ruling out alternative explanations and addressing challenges such as measurement error, missing data, and other sources of uncertainty that can affect the quality of research findings.",
  },
];

// Early Career Members
const earlyCareerMembers = [
  {
    name: "Yiou He",
    role: "Department of Psychology",
    institution: "Syracuse University",
    email: "yhe231@syr.edu",
    image: "/images/people/YH.jpg",
    website: "https://yiouhe.com/",
    bio: "Yiou He is a cognitive psychology PhD student at Syracuse University, working with Dr. David Kellen. Her current research uses formal modeling to study memory and confidence judgments. She is broadly interested in various methodological issues surrounding model evaluation and behavioral inference.",
  },
];
---

<PageLayout
  title="People"
  description="Meet the researchers behind the TMM network."
  subtitle="An international network of researchers advancing theory and measurement in psychological science."
>
  <!-- Coordinating Team -->
  <Section background="white">
    <div class="mx-auto max-w-6xl">
      <p class="mb-10 font-sans text-sm text-slate-400 dark:text-slate-500">
        Each group is ordered alphabetically by last name.
      </p>
      <ChapterHeader title="Coordinating Team" />

      <div class="mt-12 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3 md:mt-16">
        {coordinatingCommittee.sort(sortByName).map((member) => (
          <PersonCard
            name={member.name}
            institution={member.institution}
            role={member.role}
            image={member.image}
            email={member.email}
            website={member.website}
            website2={member.website2}
            bio={member.bio}
          />
        ))}
      </div>
    </div>
  </Section>

  <!-- Network Members -->
  <Section background="gray">
    <div class="mx-auto max-w-6xl">
      <ChapterHeader title="Network Members" />

      <div class="mt-12 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3 md:mt-16">
        {networkMembers.sort(sortByName).map((member) => (
          <PersonCard
            name={member.name}
            institution={member.institution}
            role={member.role}
            image={member.image}
            email={member.email}
            website={member.website}
            website2={(member as any).website2}
            bio={member.bio}
          />
        ))}
      </div>
    </div>
  </Section>

  <!-- Early Career Members -->
  <Section background="white">
    <div class="mx-auto max-w-6xl">
      <ChapterHeader title="Early Career Members" />

      <div class="mt-12 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3 md:mt-16">
        {earlyCareerMembers.sort(sortByName).map((member) => (
          <PersonCard
            name={member.name}
            institution={member.institution}
            role={member.role}
            image={member.image}
            email={member.email}
            website={member.website}
            bio={member.bio}
          />
        ))}
      </div>
    </div>
  </Section>
</PageLayout>
