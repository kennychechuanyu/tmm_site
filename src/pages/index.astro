---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import { getCollection } from "astro:content";

// Get upcoming events (TBD-dated events are included and sorted first)
const allEvents = await getCollection("events");
const now = new Date();
const upcomingEvents = allEvents
  .filter((event) => !event.data.date || event.data.date >= now)
  .sort((a, b) => {
    const ad = a.data.date?.getTime() ?? -Infinity;
    const bd = b.data.date?.getTime() ?? -Infinity;
    return ad - bd;
  })
  .slice(0, 3);

// What We Do — activities
const activities = [
  {
    title: "Unite disciplines",
    description:
      "Bringing together cognitive modelers, psychometricians, experimentalists, and philosophers.",
  },
  {
    title: "Foster dialogue",
    description:
      "Creating spaces where theoretical, modeling, and methodological assumptions can be questioned.",
  },
  {
    title: "Organize events",
    description:
      "Hosting workshops and conferences where conversations translate into concrete progress.",
  },
  {
    title: "Build collaborations",
    description:
      "Providing a platform where joint research projects can emerge from shared understanding.",
  },
];

// Focus areas
const focusAreas = [
  {
    title: "Theory–Measurement Gap",
    description:
      "What we measure often isn't what we theorize. We expose the hidden assumptions.",
  },
  {
    title: "Prediction–Explanation Gap",
    description:
      "Good predictions can come from bad theories. We investigate what it really takes for a model to explain.",
  },
  {
    title: "Cumulative Science",
    description:
      "Evidence for theories and evidence for measures get tangled. We work to untangle them—so both can genuinely accumulate.",
  },
];

const heroDescription =
  "TMM is an international network addressing the disconnect between what psychologists <em>theorize</em>, what they <em>model</em>, and what they actually <em>measure</em>.";
---

<BaseLayout
  title="TMM — Theory, Model, Measurement"
  description="An international network addressing the disconnect between what psychologists theorize, what they model, and what they actually measure."
>
  <!-- ===== Hero ===== -->
  <Hero
    subtitle="Bridging Theory and Measurement in Psychology"
    description={heroDescription}
    primaryCTA={{ label: "Join the Network", href: "/community" }}
  />

  <!-- ====================================================================
       I · Upcoming Events
       ==================================================================== -->
  <section class="relative bg-white py-20 dark:bg-slate-950 md:py-28">
    <div class="container-wide">
      <!-- Chapter header -->
      <header class="mb-12 flex items-baseline gap-6 md:mb-16 md:gap-10">
        <span class="font-serif text-5xl italic leading-none text-salmon-500 dark:text-salmon-400 md:text-6xl">
          I
        </span>
        <div class="flex flex-1 items-baseline gap-4 border-b border-slate-900/15 pb-3 dark:border-slate-100/15">
          <h2 class="font-serif text-3xl leading-none text-slate-900 dark:text-slate-100 md:text-5xl">
            Upcoming Events
          </h2>
        </div>
      </header>

      <!-- Editorial agenda list -->
      {upcomingEvents.length > 0 ? (
        <ol class="scroll-fade-in-children divide-y divide-slate-900/15 border-y border-slate-900/15 dark:divide-slate-100/15 dark:border-slate-100/15">
          {upcomingEvents.map((event) => {
            const d = event.data.date;
            const day = d ? String(d.getDate()).padStart(2, "0") : null;
            const month = d ? d.toLocaleDateString("en-US", { month: "short" }) : null;
            const year = d ? d.getFullYear() : null;
            const weekday = d ? d.toLocaleDateString("en-US", { weekday: "long" }) : "Date TBD";
            return (
              <li>
                <a
                  href={`/events/${event.slug}`}
                  class="group grid grid-cols-[auto_1fr_auto] items-center gap-5 py-6 transition-colors hover:bg-slate-50/60 dark:hover:bg-slate-900/30 md:gap-10 md:py-8"
                >
                  <!-- Date block -->
                  <div class="flex items-baseline gap-3 pl-1 text-slate-900 dark:text-slate-100">
                    {d ? (
                      <>
                        <span class="font-serif text-4xl leading-[0.85] tabular-nums md:text-6xl">
                          {day}
                        </span>
                        <div
                          class="flex flex-col font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
                          style="letter-spacing: 0.22em;"
                        >
                          <span>{month}</span>
                          <span class="font-mono tabular-nums">{year}</span>
                        </div>
                      </>
                    ) : (
                      <span class="font-serif text-2xl italic leading-[0.9] text-slate-500 dark:text-slate-500 md:text-3xl">
                        TBD
                      </span>
                    )}
                  </div>

                  <!-- Details -->
                  <div class="min-w-0 pr-2">
                    <div
                      class="mb-2 flex flex-wrap items-center gap-3 font-sans text-[10px] uppercase text-slate-500 dark:text-slate-500"
                      style="letter-spacing: 0.22em;"
                    >
                      <span>{weekday}</span>
                      <span aria-hidden="true" class="h-px w-4 bg-slate-400 dark:bg-slate-600"></span>
                      <span class="text-salmon-600 dark:text-salmon-400">{event.data.type}</span>
                      {event.data.featured && (
                        <>
                          <span aria-hidden="true" class="h-px w-4 bg-slate-400 dark:bg-slate-600"></span>
                          <span>Featured</span>
                        </>
                      )}
                    </div>
                    <h3 class="font-serif text-xl leading-tight text-slate-900 transition-colors group-hover:text-salmon-600 dark:text-slate-100 dark:group-hover:text-salmon-400 md:text-2xl">
                      {event.data.title}
                    </h3>
                    <p class="mt-1 text-sm text-slate-600 dark:text-slate-400">
                      {event.data.location}
                    </p>
                  </div>

                  <!-- Arrow -->
                  <span
                    aria-hidden="true"
                    class="hidden pr-2 text-xl text-slate-400 transition-all duration-300 group-hover:translate-x-1 group-hover:text-salmon-500 dark:text-slate-600 md:inline"
                  >
                    →
                  </span>
                </a>
              </li>
            );
          })}
        </ol>
      ) : (
        <div class="scroll-fade-in border-y border-slate-900/15 py-16 text-center dark:border-slate-100/15">
          <p class="font-serif text-xl italic text-slate-500 dark:text-slate-500">
            No events currently scheduled. Check back soon.
          </p>
        </div>
      )}

      <!-- Footer link -->
      <div class="mt-10 flex items-center justify-end md:mt-12">
        <a
          href="/events"
          class="group inline-flex items-center gap-2 font-sans text-sm font-medium text-slate-900 dark:text-slate-100"
        >
          <span class="editorial-underline">View all events</span>
          <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       II · What We Do
       ==================================================================== -->
  <section class="relative overflow-hidden bg-slate-50 py-20 dark:bg-slate-900/40 md:py-32">
    <!-- Top + bottom hairlines -->
    <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-900/10 dark:bg-slate-100/10"></div>
    <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-px bg-slate-900/10 dark:bg-slate-100/10"></div>

    <div class="container-wide">
      <!-- Chapter header -->
      <header class="mb-16 flex items-baseline gap-6 md:mb-24 md:gap-10">
        <span class="font-serif text-5xl italic leading-none text-salmon-500 dark:text-salmon-400 md:text-6xl">
          II
        </span>
        <div class="flex flex-1 items-baseline gap-4 border-b border-slate-900/15 pb-3 dark:border-slate-100/15">
          <h2 class="font-serif text-3xl leading-none text-slate-900 dark:text-slate-100 md:text-5xl">
            What We Do
          </h2>
        </div>
      </header>

      <div class="grid gap-14 lg:grid-cols-12 lg:gap-20">
        <!-- Left: manifesto -->
        <div class="scroll-fade-in-left lg:col-span-5">
          <p class="font-serif text-3xl leading-[1.12] text-slate-900 dark:text-slate-100 md:text-[2.5rem]">
            Psychologists
            <em class="font-normal text-slate-500 dark:text-slate-400">theorize</em>,
            <em class="font-normal text-slate-500 dark:text-slate-400">model</em>, and
            <em class="font-normal text-slate-500 dark:text-slate-400">measure</em>
            in disconnected ways.
          </p>
          <div class="mt-10 flex items-center gap-5">
            <div aria-hidden="true" class="h-px w-16 bg-salmon-500 dark:bg-salmon-400"></div>
            <p class="font-serif text-2xl italic text-salmon-600 dark:text-salmon-400 md:text-3xl">
              We work to align them.
            </p>
          </div>
        </div>

        <!-- Right: numbered activities -->
        <div class="scroll-fade-in-right lg:col-span-7">
          <ol class="divide-y divide-slate-900/15 border-y border-slate-900/15 dark:divide-slate-100/15 dark:border-slate-100/15">
            {activities.map((activity, i) => (
              <li class="group grid grid-cols-[auto_1fr] gap-6 py-6 md:gap-10 md:py-8">
                <span class="pt-1.5 font-mono text-[11px] tabular-nums text-slate-500 dark:text-slate-500" style="letter-spacing: 0.1em;">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <h3 class="font-serif text-xl leading-tight text-slate-900 transition-colors group-hover:text-salmon-600 dark:text-slate-100 dark:group-hover:text-salmon-400 md:text-2xl">
                    {activity.title}
                  </h3>
                  <p class="mt-2 max-w-xl text-base leading-relaxed text-slate-600 dark:text-slate-400">
                    {activity.description}
                  </p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================================
       III · Our Focus
       ==================================================================== -->
  <section class="relative bg-white py-20 dark:bg-slate-950 md:py-32">
    <div class="container-wide">
      <!-- Chapter header -->
      <header class="mb-16 flex items-baseline gap-6 md:mb-20 md:gap-10">
        <span class="font-serif text-5xl italic leading-none text-salmon-500 dark:text-salmon-400 md:text-6xl">
          III
        </span>
        <div class="flex flex-1 items-baseline gap-4 border-b border-slate-900/15 pb-3 dark:border-slate-100/15">
          <h2 class="font-serif text-3xl leading-none text-slate-900 dark:text-slate-100 md:text-5xl">
            Our Focus
          </h2>
        </div>
      </header>

      <p class="mb-14 font-serif text-lg italic text-slate-600 dark:text-slate-400 md:mb-16 md:text-xl">
        Three questions we return to, again and again.
      </p>

      <!-- Three editorial plates -->
      <div class="scroll-fade-in-children grid gap-10 md:grid-cols-3 md:gap-12">
        {focusAreas.map((area, i) => (
          <article class="group relative pt-10">
            <!-- Top rule (static) -->
            <div aria-hidden="true" class="absolute inset-x-0 top-0 h-px bg-slate-900 dark:bg-slate-100"></div>
            <!-- Top rule (salmon sweep on hover) -->
            <div
              aria-hidden="true"
              class="absolute inset-x-0 top-0 h-[3px] w-0 bg-salmon-500 transition-[width] duration-[900ms] ease-out group-hover:w-full dark:bg-salmon-400"
            ></div>

            <!-- Numeral + label -->
            <div class="mb-8 flex items-baseline justify-between">
              <span class="font-serif italic leading-[0.8] text-slate-900 transition-colors duration-500 group-hover:text-salmon-500 dark:text-slate-100 dark:group-hover:text-salmon-400" style="font-size: 5.5rem;">
                {String(i + 1).padStart(2, "0")}
              </span>
              <span
                class="font-sans text-[10px] uppercase text-slate-400 dark:text-slate-600"
                style="letter-spacing: 0.22em;"
              >
                Theme
              </span>
            </div>

            <h3 class="font-serif text-2xl leading-[1.2] text-slate-900 dark:text-slate-100 md:text-[1.7rem]">
              {area.title}
            </h3>

            <p class="mt-4 text-base leading-relaxed text-slate-600 dark:text-slate-400">
              {area.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
